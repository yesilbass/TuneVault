<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <StackPane alignment="TOP_LEFT"
                   styleClass="playlist-page-stack"
                   maxWidth="Infinity" maxHeight="Infinity">

            <ScrollPane fx:id="contentRow"
                        fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxWidth="Infinity" maxHeight="Infinity"
                        minWidth="0" minHeight="0"
                        styleClass="playlist-page-scroll"
                        style="-fx-padding: 0 0 32 0;">
                <content>
                    <VBox spacing="0" minHeight="0" styleClass="playlist-page-scroll-root">

                        <VBox fx:id="playlistSongsCard"
                              spacing="0"
                              styleClass="playlist-page-main-card, card-glow">

                            <!-- Hero / identity -->
                            <VBox styleClass="playlist-page-header-block" spacing="0">
                                <HBox alignment="TOP_LEFT" spacing="24" styleClass="playlist-page-header-row">
                                    <StackPane fx:id="selectedPlaylistCover"
                                               styleClass="playlist-page-cover-host"
                                               minWidth="132" minHeight="132"
                                               prefWidth="132" prefHeight="132"
                                               maxWidth="132" maxHeight="132"/>
                                    <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="playlist-page-title-stack">
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <Label text="PLAYLIST" styleClass="playlist-page-eyebrow"/>
                                            <Label text="COLLECTION" styleClass="playlist-page-pill"/>
                                        </HBox>
                                        <Label fx:id="selectedPlaylistLabel"
                                               text="No playlist selected"
                                               wrapText="true"
                                               maxWidth="Infinity"
                                               styleClass="playlist-page-title"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="playlist-page-stats-row">
                                            <Label fx:id="songCountLabel"
                                                   text="0 tracks"
                                                   styleClass="playlist-page-stat"/>
                                            <Label text="·" styleClass="playlist-page-stat-sep"/>
                                            <Label fx:id="totalDurationLabel"
                                                   text="0 minutes"
                                                   styleClass="playlist-page-stat"/>
                                            <Label fx:id="playlistVisibilityLabel"
                                                   text="Private"
                                                   managed="false" visible="false"
                                                   styleClass="profile-playlist-vis, profile-playlist-vis-private"/>
                                        </HBox>
                                    </VBox>
                                    <Button text="+ Add songs"
                                            onAction="#handleShowSearchSongs"
                                            styleClass="playlist-page-add-btn"
                                            mnemonicParsing="false"/>
                                </HBox>
                            </VBox>

                            <Separator styleClass="playlist-page-separator"/>

                            <!-- Transport + sort -->
                            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="playlist-page-controls-strip">
                                <Button fx:id="playlistToolbarPlayButton"
                                        text="▶"
                                        onAction="#handlePlaylistToolbarPlay"
                                        styleClass="playlist-toolbar-play"
                                        prefWidth="52" prefHeight="52"
                                        minWidth="52" minHeight="52"
                                        mnemonicParsing="false"/>
                                <Button fx:id="playlistToolbarShuffleButton"
                                        text="⇄"
                                        onAction="#handlePlaylistToolbarShuffle"
                                        styleClass="playlist-toolbar-secondary"
                                        prefWidth="48" prefHeight="48"
                                        minWidth="48" minHeight="48"
                                        mnemonicParsing="false"/>
                                <MenuButton fx:id="playlistToolbarMoreMenu"
                                            text="⋯"
                                            mnemonicParsing="false"
                                            styleClass="playlist-toolbar-secondary, playlist-toolbar-more"
                                            prefWidth="48" prefHeight="48"
                                            minWidth="48" minHeight="48"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <MenuButton fx:id="playlistOrderMenu"
                                            text="Playlist order"
                                            mnemonicParsing="false"
                                            styleClass="playlist-order-menu"/>
                            </HBox>

                            <Separator styleClass="playlist-page-separator"/>

                            <!-- Track list region -->
                            <VBox spacing="10" styleClass="playlist-page-tracks-wrap">
                                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="playlist-tracks-section-head">
                                    <Label text="Tracks" styleClass="playlist-tracks-head-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Double-click a row to play · ⋯ for options"
                                           styleClass="playlist-tracks-head-subtitle"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="playlist-tracks-grid-header">
                                    <Region prefWidth="3" minWidth="3" maxWidth="3"/>
                                    <Label text="#" minWidth="28" prefWidth="28" maxWidth="28" alignment="CENTER_RIGHT"
                                           styleClass="playlist-tracks-grid-hdr-muted"/>
                                    <Region prefWidth="48" minWidth="48" maxWidth="48"/>
                                    <Label text="TITLE" styleClass="playlist-tracks-grid-hdr-primary" HBox.hgrow="ALWAYS"/>
                                    <Label text="ALBUM" minWidth="120" prefWidth="188" maxWidth="220"
                                           styleClass="playlist-tracks-grid-hdr-muted"/>
                                    <Label text="TIME" minWidth="52" prefWidth="52" maxWidth="52" alignment="CENTER_RIGHT"
                                           styleClass="playlist-tracks-grid-hdr-muted"/>
                                    <Region minWidth="78" prefWidth="78" maxWidth="78"/>
                                </HBox>
                                <ListView fx:id="playlistSongsListView"
                                          minHeight="160"
                                          styleClass="playlist-tracks-list"/>
                            </VBox>

                            <VBox fx:id="suggestionsSection"
                                  spacing="14"
                                  visible="false"
                                  managed="false"
                                  styleClass="playlist-suggestions-block">

                                <Separator styleClass="playlist-page-separator"/>

                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="playlist-suggestions-head">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Suggested for you" styleClass="playlist-suggestions-title"/>
                                        <Label fx:id="suggestionSubtitleLabel"
                                               text="From your library — ranked by fit to this playlist and your taste."
                                               styleClass="playlist-suggestions-subtitle"/>
                                    </VBox>
                                    <Label text="✦ Smart picks" styleClass="badge, badge-accent"/>
                                </HBox>

                                <ListView fx:id="suggestedSongsListView"
                                          minHeight="80"
                                          styleClass="playlist-suggestions-list"/>
                            </VBox>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

            <VBox fx:id="searchSongsPanel"
                  visible="false"
                  managed="false"
                  maxWidth="340" minWidth="340" prefWidth="340"
                  spacing="14"
                  StackPane.alignment="TOP_RIGHT"
                  translateX="-8"
                  styleClass="card-elevated, playlist-search-flyout">

                <HBox alignment="CENTER_LEFT">
                    <Label text="Add songs" styleClass="heading-md"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕"
                            onAction="#handleHideSearchSongs"
                            prefWidth="36" prefHeight="36"
                            styleClass="btn-danger"/>
                </HBox>

                <TextField fx:id="searchSongsField"
                           promptText="Title, artist, album or genre…"
                           prefHeight="42"/>

                <Label text="Double-click a row to play. Use + or the checkmark to add or remove from the playlist."
                       wrapText="true"
                       styleClass="caption"/>

                <ListView fx:id="searchResultsListView"
                          VBox.vgrow="ALWAYS"
                          prefHeight="380"/>

            </VBox>

        </StackPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
