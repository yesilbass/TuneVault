<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <!-- ── LEFT: app rail ─────────────────────────── -->
    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>
    <!-- ── CENTER: scrollable playlist body ──── -->
    <center>
        <StackPane alignment="TOP_LEFT"
                   style="-fx-padding: 16 32 16 32;"
                   maxWidth="Infinity" maxHeight="Infinity">

            <ScrollPane fx:id="contentRow"
                        fitToWidth="true" fitToHeight="false"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        maxWidth="Infinity" maxHeight="Infinity"
                        minWidth="0" minHeight="0"
                        style="-fx-padding: 0 0 24 0;">
                    <content>
                        <VBox spacing="0" minHeight="0">

                            <VBox fx:id="playlistSongsCard" spacing="12" styleClass="card">

                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <StackPane fx:id="selectedPlaylistCover"
                                               styleClass="playlist-page-cover-host"/>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label fx:id="selectedPlaylistLabel"
                                               text="No playlist selected"
                                               styleClass="heading-lg"/>
                                        <HBox spacing="16" alignment="CENTER_LEFT">
                                            <Label fx:id="songCountLabel"
                                                   text="Songs: 0"
                                                   styleClass="body-sm, text-accent"/>
                                            <Label fx:id="totalDurationLabel"
                                                   text="Duration: 0:00"
                                                   styleClass="body-sm, text-accent"/>
                                            <Label fx:id="playlistVisibilityLabel"
                                                   text="Private"
                                                   managed="false" visible="false"
                                                   styleClass="profile-playlist-vis, profile-playlist-vis-private"/>
                                        </HBox>
                                    </VBox>
                                    <Button text="+ Add Song"
                                            onAction="#handleShowSearchSongs"
                                            styleClass="btn-accent-soft"/>
                                </HBox>

                                <Separator/>

                                <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="playlist-songs-toolbar">
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <MenuButton fx:id="playlistOrderMenu"
                                                text="Playlist order"
                                                mnemonicParsing="false"
                                                styleClass="btn-ghost, playlist-order-menu"/>
                                </HBox>

                                <ListView fx:id="playlistSongsListView" minHeight="160"/>

                                <VBox fx:id="suggestionsSection"
                                      spacing="12"
                                      visible="false"
                                      managed="false"
                                      styleClass="playlist-suggestions-block">

                                    <Separator/>

                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label text="Suggested for you" styleClass="heading-md"/>
                                            <Label fx:id="suggestionSubtitleLabel"
                                                   text="From your library — ranked by fit to this playlist and your taste."
                                                   styleClass="caption"/>
                                        </VBox>
                                        <Label text="✦ Smart picks" styleClass="badge, badge-accent"/>
                                    </HBox>

                                    <ListView fx:id="suggestedSongsListView" minHeight="80"/>
                                </VBox>
                            </VBox>

                        </VBox>
                    </content>
            </ScrollPane>

            <!-- Floating search panel (top-right overlay) -->
            <VBox fx:id="searchSongsPanel"
                  visible="false"
                  managed="false"
                  maxWidth="340" minWidth="340" prefWidth="340"
                  spacing="14"
                  StackPane.alignment="TOP_RIGHT"
                  translateX="-8"
                  styleClass="card-elevated">
                <children>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Add Songs" styleClass="heading-md"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕"
                                onAction="#handleHideSearchSongs"
                                prefWidth="36" prefHeight="36"
                                styleClass="btn-danger"/>
                    </HBox>

                    <TextField fx:id="searchSongsField"
                               promptText="Title, artist, album or genre…"
                               prefHeight="42"/>

                    <Label text="Double-click a row to play. Use + or the checkmark to add or remove from the playlist."
                           wrapText="true"
                           styleClass="caption"/>

                    <ListView fx:id="searchResultsListView"
                              VBox.vgrow="ALWAYS"
                              prefHeight="380"/>

                </children>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
