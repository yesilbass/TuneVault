<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.SearchPageController"
            prefWidth="1280.0" prefHeight="820.0"
            style="-fx-background-color: linear-gradient(to bottom right, #090912, #0f0f1e);">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 32 18 32;
                     -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                     -fx-border-width: 0 0 1 0;">
            <Button text="← Menu"
                    onAction="#handleBackToMenu"
                    prefWidth="110" prefHeight="38"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-text-fill: #94a3b8;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 19;
                           -fx-border-color: rgba(255,255,255,0.1);
                           -fx-border-radius: 19;
                           -fx-border-width: 1;" />

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🔍"
                           style="-fx-font-size: 20px;" />
                    <Label text="Search"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </HBox>
            </StackPane>

            <Region prefWidth="110" />
        </HBox>
    </top>

    <!-- ── CENTER ────────────────────────────────── -->
    <center>
        <VBox spacing="0" style="-fx-padding: 16 32 0 32;">

            <!-- Search bar card (always visible) -->
            <VBox spacing="10"
                  style="-fx-background-color: #14141e;
                         -fx-background-radius: 22;
                         -fx-border-color: rgba(255,255,255,0.08);
                         -fx-border-radius: 22;
                         -fx-border-width: 1;
                         -fx-padding: 20 24 18 24;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);">

                <Label text="What do you want to play?"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               HBox.hgrow="ALWAYS"
                               promptText="Search songs, artists, albums, genres…"
                               prefHeight="46" />

                    <Button text="✕  Clear"
                            onAction="#handleClearSearch"
                            prefWidth="96" prefHeight="46"
                            style="-fx-background-color: rgba(255,255,255,0.07);
                                   -fx-text-fill: #52525b;
                                   -fx-font-size: 13px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 13;
                                   -fx-border-color: rgba(255,255,255,0.08);
                                   -fx-border-radius: 13;
                                   -fx-border-width: 1;" />
                </HBox>

                <Label fx:id="resultsSummaryLabel"
                       text=""
                       style="-fx-text-fill: #3d3d5c; -fx-font-size: 13px;" />
            </VBox>

            <Region prefHeight="16" />

            <!-- IDLE: Recent searches (visible when search is empty) -->
            <VBox fx:id="recentSection"
                  spacing="0"
                  style="-fx-background-color: #14141e;
                         -fx-background-radius: 22;
                         -fx-border-color: rgba(255,255,255,0.08);
                         -fx-border-radius: 22;
                         -fx-border-width: 1;
                         -fx-padding: 20 24 8 24;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);">

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                    <Label text="Recent Searches"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Clear All"
                            onAction="#handleClearRecentSearches"
                            prefHeight="32"
                            style="-fx-background-color: rgba(255,255,255,0.06);
                                   -fx-text-fill: #52525b;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 12;
                                   -fx-padding: 0 14 0 14;" />
                </HBox>

                <ListView fx:id="recentSearchesListView"
                          prefHeight="460"
                          style="-fx-background-color: transparent; -fx-border-color: transparent;" />
            </VBox>

            <!-- RESULTS: Shown while typing (scrollable) -->
            <ScrollPane fx:id="resultsScrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        visible="false"
                        managed="false"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox spacing="16" style="-fx-padding: 0 0 28 0;">

                        <!-- Songs -->
                        <VBox fx:id="songResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              style="-fx-background-color: #14141e;
                                     -fx-background-radius: 22;
                                     -fx-border-color: rgba(255,255,255,0.08);
                                     -fx-border-radius: 22;
                                     -fx-border-width: 1;
                                     -fx-padding: 20 24 8 24;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane prefWidth="30" prefHeight="30"
                                           style="-fx-background-color: rgba(139,92,246,0.15);
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: rgba(139,92,246,0.2);
                                                  -fx-border-radius: 10;
                                                  -fx-border-width: 1;">
                                    <Label text="♫"
                                           style="-fx-font-size: 13px; -fx-text-fill: #a78bfa;" />
                                </StackPane>
                                <Label text="Songs"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            </HBox>

                            <ListView fx:id="songResultsListView"
                                      prefHeight="340"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                        </VBox>

                        <!-- Artists -->
                        <VBox fx:id="artistResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              style="-fx-background-color: #14141e;
                                     -fx-background-radius: 22;
                                     -fx-border-color: rgba(255,255,255,0.08);
                                     -fx-border-radius: 22;
                                     -fx-border-width: 1;
                                     -fx-padding: 20 24 8 24;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane prefWidth="30" prefHeight="30"
                                           style="-fx-background-color: rgba(244,63,94,0.12);
                                                  -fx-background-radius: 15;
                                                  -fx-border-color: rgba(244,63,94,0.18);
                                                  -fx-border-radius: 15;
                                                  -fx-border-width: 1;">
                                    <Label text="◎"
                                           style="-fx-font-size: 13px; -fx-text-fill: #fb7185;" />
                                </StackPane>
                                <Label text="Artists"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                            </HBox>

                            <ListView fx:id="artistResultsListView"
                                      prefHeight="220"
                                      style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>

</BorderPane>
