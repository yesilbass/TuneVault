<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.SearchPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
            <Button text="← Back"
                    onAction="#handleBackToMenu"
                    styleClass="btn-nav"/>

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🔍" style="-fx-font-size: 20px;"/>
                    <Label text="Search" styleClass="heading-xl"/>
                </HBox>
            </StackPane>

            <Region prefWidth="110"/>
        </HBox>
    </top>

    <!-- ── CENTER ────────────────────────────────── -->
    <center>
        <VBox spacing="0" style="-fx-padding: 16 32 0 32;">

            <!-- Search bar card (always visible) -->
            <VBox fx:id="searchInputCard" spacing="10" styleClass="card">

                <Label text="What do you want to play?" styleClass="heading-lg"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               HBox.hgrow="ALWAYS"
                               promptText="Search songs, artists, albums, genres…"
                               prefHeight="46"/>

                    <Button text="✕  Clear"
                            onAction="#handleClearSearch"
                            styleClass="btn-secondary"/>
                </HBox>

                <Label fx:id="resultsSummaryLabel"
                       text=""
                       styleClass="caption"/>
            </VBox>

            <Region prefHeight="16"/>

            <!-- IDLE: Recent searches (visible when search is empty) -->
            <VBox fx:id="recentSection" spacing="0" styleClass="card">

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                    <Label text="Recent Searches" styleClass="heading-md"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Clear All"
                            onAction="#handleClearRecentSearches"
                            styleClass="btn-ghost"/>
                </HBox>

                <ListView fx:id="recentSearchesListView" prefHeight="460"/>
            </VBox>

            <!-- RESULTS: Shown while typing (scrollable) -->
            <ScrollPane fx:id="resultsScrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        visible="false"
                        managed="false">
                <content>
                    <VBox spacing="16" style="-fx-padding: 0 0 28 0;">

                        <!-- Songs -->
                        <VBox fx:id="songResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane styleClass="icon-box-sm, icon-box-violet">
                                    <Label text="♫" styleClass="text-accent"/>
                                </StackPane>
                                <Label text="Songs" styleClass="heading-md"/>
                            </HBox>

                            <ListView fx:id="songResultsListView" prefHeight="340"/>
                        </VBox>

                        <!-- Artists -->
                        <VBox fx:id="artistResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane styleClass="icon-box-sm, icon-box-rose">
                                    <Label text="◎" style="-fx-text-fill: #fb7185;"/>
                                </StackPane>
                                <Label text="Artists" styleClass="heading-md"/>
                            </HBox>

                            <ListView fx:id="artistResultsListView" prefHeight="220"/>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml"/>
    </bottom>

</BorderPane>
