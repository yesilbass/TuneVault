<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.mainmenu.MainMenuController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 22 24 18 24;">
            <children>
                <VBox spacing="4">
                    <children>
                        <Label text="TuneVault"
                               style="-fx-text-fill: white; -fx-font-size: 42px; -fx-font-weight: bold;" />
                        <Label fx:id="welcomeLabel"
                               text="Welcome"
                               style="-fx-text-fill: #cbd5e1; -fx-font-size: 16px;" />
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 18;"
                        prefWidth="100" prefHeight="42" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 32 24 36 24;">
            <children>
                <VBox alignment="CENTER" spacing="8">
                    <children>
                        <Label text="Choose a feature below to continue"
                               style="-fx-text-fill: #e2e8f0; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="Your playlists, listening recap, and genre quiz are all here."
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <HBox alignment="CENTER" spacing="28">
                    <children>

                        <VBox alignment="CENTER" spacing="16"
                              prefWidth="300" prefHeight="220"
                              style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 28;">
                            <children>
                                <Label text="Playlists"
                                       style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                <Label text="Create, manage, and organize your music library."
                                       wrapText="true"
                                       maxWidth="230"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                                <Region prefHeight="8" />
                                <Button text="Open"
                                        onAction="#openPlaylistsPage"
                                        prefWidth="170" prefHeight="46"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 18;" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="16"
                              prefWidth="300" prefHeight="220"
                              style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 28;">
                            <children>
                                <Label text="Wrapped"
                                       style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                <Label text="See your top songs, artists, genres, and listening stats."
                                       wrapText="true"
                                       maxWidth="230"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                                <Region prefHeight="8" />
                                <Button text="Open"
                                        onAction="#openWrappedPage"
                                        prefWidth="170" prefHeight="46"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 18;" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="16"
                              prefWidth="300" prefHeight="220"
                              style="-fx-background-color: white; -fx-background-radius: 28; -fx-padding: 28;">
                            <children>
                                <Label text="Find Your Genre"
                                       style="-fx-text-fill: #0f172a; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                <Label text="Take a quiz to discover the genre that fits you best."
                                       wrapText="true"
                                       maxWidth="230"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                                <Region prefHeight="8" />
                                <Button text="Open"
                                        onAction="#openFindYourGenrePage"
                                        prefWidth="170" prefHeight="46"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 18;" />
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>