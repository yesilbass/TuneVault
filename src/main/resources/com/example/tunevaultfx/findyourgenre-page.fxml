<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.findyourgenre.FindYourGenrePageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            style="-fx-background-color: linear-gradient(to bottom right, #090912, #0f0f1e);">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 32 18 32;
                     -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                     -fx-border-width: 0 0 1 0;">
            <Button text="← Menu"
                    onAction="#handleBackToMenu"
                    prefWidth="110" prefHeight="38"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-text-fill: #94a3b8;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 19;
                           -fx-border-color: rgba(255,255,255,0.1);
                           -fx-border-radius: 19;
                           -fx-border-width: 1;" />

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🎯"
                           style="-fx-font-size: 22px;" />
                    <Label text="Find Your Genre"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </HBox>
            </StackPane>

            <Region prefWidth="110" />
        </HBox>
    </top>

    <!-- ── CENTER: Quiz ───────────────────────────── -->
    <center>
        <VBox alignment="CENTER" spacing="28"
              style="-fx-padding: 32 48 28 48;">
            <children>

                <!-- Quiz card -->
                <VBox spacing="28" alignment="CENTER"
                      maxWidth="760" prefWidth="760"
                      style="-fx-background-color: #14141e;
                             -fx-background-radius: 28;
                             -fx-border-color: rgba(255,255,255,0.08);
                             -fx-border-radius: 28;
                             -fx-border-width: 1;
                             -fx-padding: 44 48 44 48;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.55),32,0,0,10);">
                    <children>

                        <!-- Progress & question -->
                        <VBox spacing="14" alignment="CENTER">

                            <!-- Progress label + bar area -->
                            <HBox alignment="CENTER" spacing="12">
                                <StackPane prefWidth="36" prefHeight="36"
                                           style="-fx-background-color: rgba(139,92,246,0.15);
                                                  -fx-background-radius: 18;
                                                  -fx-border-color: rgba(139,92,246,0.25);
                                                  -fx-border-radius: 18;
                                                  -fx-border-width: 1;">
                                    <Label text="?"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;" />
                                </StackPane>
                                <Label fx:id="progressLabel"
                                       text="Question 1 of 4"
                                       style="-fx-font-size: 13px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #6b6b8e;" />
                            </HBox>

                            <!-- Question text -->
                            <Label fx:id="questionLabel"
                                   wrapText="true"
                                   text="Question goes here"
                                   maxWidth="620"
                                   style="-fx-font-size: 26px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #ffffff;
                                          -fx-alignment: center;
                                          -fx-text-alignment: center;" />
                        </VBox>

                        <!-- 2×2 Answer grid -->
                        <GridPane hgap="16" vgap="16" alignment="CENTER">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="310" />
                                <ColumnConstraints prefWidth="310" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints prefHeight="66" />
                                <RowConstraints prefHeight="66" />
                            </rowConstraints>
                            <children>

                                <Button fx:id="answerButton1"
                                        text="Answer 1"
                                        onAction="#handleAnswer1"
                                        GridPane.columnIndex="0" GridPane.rowIndex="0"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        style="-fx-background-color: rgba(139,92,246,0.1);
                                               -fx-text-fill: #c4b5fd;
                                               -fx-font-size: 15px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;
                                               -fx-border-color: rgba(139,92,246,0.25);
                                               -fx-border-radius: 18;
                                               -fx-border-width: 1;" />

                                <Button fx:id="answerButton2"
                                        text="Answer 2"
                                        onAction="#handleAnswer2"
                                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        style="-fx-background-color: rgba(139,92,246,0.1);
                                               -fx-text-fill: #c4b5fd;
                                               -fx-font-size: 15px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;
                                               -fx-border-color: rgba(139,92,246,0.25);
                                               -fx-border-radius: 18;
                                               -fx-border-width: 1;" />

                                <Button fx:id="answerButton3"
                                        text="Answer 3"
                                        onAction="#handleAnswer3"
                                        GridPane.columnIndex="0" GridPane.rowIndex="1"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        style="-fx-background-color: rgba(139,92,246,0.1);
                                               -fx-text-fill: #c4b5fd;
                                               -fx-font-size: 15px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;
                                               -fx-border-color: rgba(139,92,246,0.25);
                                               -fx-border-radius: 18;
                                               -fx-border-width: 1;" />

                                <Button fx:id="answerButton4"
                                        text="Answer 4"
                                        onAction="#handleAnswer4"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        style="-fx-background-color: rgba(139,92,246,0.1);
                                               -fx-text-fill: #c4b5fd;
                                               -fx-font-size: 15px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;
                                               -fx-border-color: rgba(139,92,246,0.25);
                                               -fx-border-radius: 18;
                                               -fx-border-width: 1;" />

                            </children>
                        </GridPane>

                        <!-- Result + restart -->
                        <VBox alignment="CENTER" spacing="16">
                            <Label fx:id="resultLabel"
                                   text=""
                                   style="-fx-font-size: 32px;
                                          -fx-font-weight: bold;
                                          -fx-text-fill: #a78bfa;" />

                            <Button fx:id="restartButton"
                                    text="↺  Play Again"
                                    visible="false"
                                    onAction="#handleRestartQuiz"
                                    prefWidth="200" prefHeight="46"
                                    style="-fx-background-color: rgba(139,92,246,0.18);
                                           -fx-text-fill: #a78bfa;
                                           -fx-font-size: 14px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 23;
                                           -fx-border-color: rgba(139,92,246,0.3);
                                           -fx-border-radius: 23;
                                           -fx-border-width: 1;" />
                        </VBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>

</BorderPane>
