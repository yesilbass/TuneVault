<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.findyourgenre.FindYourGenrePageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
            <Button text="← Back"
                    onAction="#handleBackToMenu"
                    styleClass="btn-nav" />

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🎯" style="-fx-font-size: 22px;" />
                    <Label text="Find Your Genre" styleClass="heading-xl" />
                </HBox>
            </StackPane>

            <Region prefWidth="110" />
        </HBox>
    </top>

    <!-- ── CENTER: Quiz ───────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fx:id="quizContainer" alignment="CENTER" spacing="28"
                      styleClass="page-content">

                    <!-- Quiz card -->
                    <VBox fx:id="quizCard" spacing="28" alignment="CENTER"
                          maxWidth="760" prefWidth="760"
                          styleClass="card-elevated"
                          style="-fx-padding: 44 48 44 48;">

                        <!-- Progress & question -->
                        <VBox spacing="14" alignment="CENTER">

                            <HBox alignment="CENTER" spacing="12">
                                <StackPane>
                                    <styleClass>
                                        <String fx:value="icon-box-sm" />
                                        <String fx:value="icon-box-violet" />
                                    </styleClass>
                                    <Label text="?"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;" />
                                </StackPane>
                                <Label fx:id="progressLabel"
                                       text="Question 1 of 4"
                                       styleClass="body-sm" />
                            </HBox>

                            <Label fx:id="questionLabel"
                                   wrapText="true"
                                   text="Question goes here"
                                   maxWidth="620"
                                   alignment="CENTER"
                                   textAlignment="CENTER"
                                   styleClass="heading-xl" />
                        </VBox>

                        <!-- 2×2 Answer grid -->
                        <GridPane hgap="16" vgap="16" alignment="CENTER">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="310" />
                                <ColumnConstraints prefWidth="310" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints prefHeight="66" />
                                <RowConstraints prefHeight="66" />
                            </rowConstraints>
                            <children>

                                <Button fx:id="answerButton1"
                                        text="Answer 1"
                                        onAction="#handleAnswer1"
                                        GridPane.columnIndex="0" GridPane.rowIndex="0"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        styleClass="quiz-answer" />

                                <Button fx:id="answerButton2"
                                        text="Answer 2"
                                        onAction="#handleAnswer2"
                                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        styleClass="quiz-answer" />

                                <Button fx:id="answerButton3"
                                        text="Answer 3"
                                        onAction="#handleAnswer3"
                                        GridPane.columnIndex="0" GridPane.rowIndex="1"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        styleClass="quiz-answer" />

                                <Button fx:id="answerButton4"
                                        text="Answer 4"
                                        onAction="#handleAnswer4"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                                        maxWidth="Infinity" maxHeight="Infinity"
                                        styleClass="quiz-answer" />

                            </children>
                        </GridPane>

                        <!-- Result + restart -->
                        <VBox alignment="CENTER" spacing="16">
                            <Label fx:id="resultLabel" text="">
                                <styleClass>
                                    <String fx:value="heading-2xl" />
                                    <String fx:value="text-accent" />
                                </styleClass>
                            </Label>

                            <Button fx:id="restartButton"
                                    text="↺  Play Again"
                                    visible="false"
                                    onAction="#handleRestartQuiz"
                                    prefWidth="200" prefHeight="46"
                                    styleClass="btn-accent-soft" />
                        </VBox>

                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>

</BorderPane>
