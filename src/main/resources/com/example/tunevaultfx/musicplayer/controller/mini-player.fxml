<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tunevaultfx.musicplayer.controller.MiniPlayerController"
      styleClass="player-bar"
      prefHeight="98">

    <!-- Progress slider — full width, top -->
    <Slider fx:id="miniProgressSlider"
            maxWidth="Infinity"
            VBox.vgrow="NEVER"
            style="-fx-padding: 0;" />

    <!-- Main content row -->
    <HBox VBox.vgrow="ALWAYS" alignment="CENTER">

        <!-- LEFT: Album art + Song info -->
        <HBox prefWidth="290" minWidth="290" maxWidth="290"
              spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 0 0 0 20;">

            <StackPane prefWidth="50" prefHeight="50" minWidth="50" minHeight="50"
                       styleClass="album-art-mini"
                       onMouseClicked="#handleOpenNowPlaying">
                <Label text="♫" style="-fx-font-size: 22px; -fx-text-fill: rgba(196,181,253,0.7);" />
            </StackPane>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="miniSongLabel"
                       text="No song playing"
                       maxWidth="190"
                       styleClass="heading-sm"
                       onMouseClicked="#handleOpenSongProfile"
                       style="-fx-cursor: hand;" />
                <Hyperlink fx:id="miniArtistLink"
                           text=""
                           styleClass="body-sm mini-player-text-link"
                           onAction="#handleOpenArtistProfile" />
                <Hyperlink fx:id="miniPlaylistLink"
                           text=""
                           maxWidth="190"
                           styleClass="caption mini-player-text-link"
                           onAction="#handleOpenCurrentPlaylist" />
            </VBox>
        </HBox>

        <!-- CENTER: Elapsed · controls · total -->
        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
            <HBox alignment="CENTER" spacing="12">
                <Label fx:id="miniElapsedLabel"
                       text="0:00"
                       minWidth="48" prefWidth="52"
                       alignment="CENTER_RIGHT"
                       styleClass="caption, mini-player-time-elapsed" />
                <HBox spacing="4" alignment="CENTER">

                <Button fx:id="miniShuffleButton"
                        text="⇄"
                        onAction="#handleMiniShuffle"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38" />

                <Button text="⏮"
                        onAction="#handleMiniPrevious"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38" />

                <Button fx:id="miniPlayPauseButton"
                        text="▶"
                        onAction="#handleMiniPlayPause"
                        styleClass="player-btn-main"
                        prefWidth="60" prefHeight="48" />

                <Button text="⏭"
                        onAction="#handleMiniNext"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38" />

                <Button fx:id="miniLoopButton"
                        text="↻"
                        onAction="#handleMiniLoop"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38"
                        style="-fx-font-size: 19px;" />

                <Region prefWidth="12" />

                <Button fx:id="miniLikeButton"
                        text="♡"
                        onAction="#handleMiniLike"
                        styleClass="player-btn-like"
                        prefWidth="60" prefHeight="38" />

                <Button fx:id="miniAddButton"
                        text="+"
                        onAction="#handleMiniAddToPlaylist"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38"
                        style="-fx-font-size: 20px;" />

                <Button fx:id="miniQueueButton"
                        text="☰"
                        onAction="#handleOpenQueue"
                        styleClass="player-btn-queue"
                        prefWidth="60" prefHeight="38" />

                <Button fx:id="miniExpandedPlayerButton"
                        text="⤢"
                        onAction="#handleOpenExpandedPlayer"
                        styleClass="player-btn"
                        prefWidth="60" prefHeight="38" />

                </HBox>
                <Label fx:id="miniTotalLabel"
                       text="0:00"
                       minWidth="48" prefWidth="52"
                       alignment="CENTER_LEFT"
                       styleClass="caption, mini-player-time-total" />
            </HBox>
        </StackPane>

    </HBox>
</VBox>
