<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.musicplayer.controller.ExpandedPlayerController"
           fx:id="overlayRoot"
           id="expandedPlayerOverlay"
           visible="false"
           managed="false"
           pickOnBounds="true">

    <!-- Backdrop -->
    <StackPane fx:id="backdropPane"
               styleClass="overlay-backdrop"
               onMouseClicked="#handleBackdropClick" />

    <!-- Player Card: pref-sized so StackPane centers a compact panel (no tall empty band) -->
    <VBox fx:id="playerCard"
          styleClass="overlay-card"
          alignment="TOP_CENTER"
          maxWidth="920"
          prefWidth="920"
          spacing="0"
          onMouseClicked="#handleConsumeClick">
        <children>

            <!-- Header row -->
            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header"
                  maxWidth="Infinity">
                <children>
                    <VBox spacing="2">
                        <Label text="NOW PLAYING"
                               styleClass="overline, text-accent" />
                        <Label text="Expanded Player"
                               styleClass="heading-md" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✕"
                            onAction="#handleClose"
                            styleClass="btn-icon"
                            prefWidth="40" prefHeight="40" />
                </children>
            </HBox>

            <!-- Center the art + track block as a unit (Spotify-style, not edge-pinned) -->
            <HBox alignment="CENTER"
                  maxWidth="Infinity"
                  style="-fx-padding: 28 36 36 36;">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="36">
                        <children>

                    <!-- Album Art -->
                    <VBox alignment="CENTER" spacing="12">
                        <StackPane prefWidth="260" prefHeight="260" minWidth="260" minHeight="260"
                                   maxWidth="260" maxHeight="260"
                                   styleClass="album-art-large">
                            <Label text="♫"
                                   style="-fx-font-size: 80px;
                                          -fx-text-fill: rgba(167,139,250,0.2);
                                          -fx-font-weight: bold;" />
                        </StackPane>
                        <Label text="TuneVault Player"
                               styleClass="body-sm" />
                    </VBox>

                    <!-- Song Info + Controls (fixed width — no grow into empty horizontal space) -->
                    <VBox spacing="20" alignment="TOP_LEFT" prefWidth="504" maxWidth="504" minWidth="504">
                        <children>

                            <!-- Track info -->
                            <VBox spacing="8">
                                <Label text="CURRENT TRACK"
                                       styleClass="overline" />

                                <Label fx:id="titleLabel"
                                       text="No song playing"
                                       wrapText="true"
                                       maxWidth="496"
                                       styleClass="heading-2xl"
                                       style="-fx-font-size: 36px; -fx-line-spacing: -2;" />

                                <Hyperlink fx:id="artistLink"
                                           text=""
                                           styleClass="heading-md expanded-artist-link"
                                           onAction="#handleOpenArtistProfile" />

                                <Label fx:id="albumLabel"
                                       text="Album: -"
                                       styleClass="body-sm" />

                                <Hyperlink text="Song details"
                                           onAction="#handleOpenSongProfile"
                                           styleClass="body-sm expanded-song-details-link"
                                           style="-fx-padding: 4 0 0 0;" />
                            </VBox>

                            <!-- Progress section -->
                            <VBox spacing="8"
                                  styleClass="progress-card"
                                  maxWidth="504">
                                <Slider fx:id="progressSlider"
                                        prefWidth="464"
                                        maxWidth="464" />
                                <HBox alignment="CENTER_LEFT" maxWidth="464">
                                    <Label text="Progress"
                                           styleClass="caption, text-muted" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="timeLabel"
                                           text="0:00 / 0:00"
                                           styleClass="body expanded-time-label" />
                                </HBox>
                            </VBox>

                            <!-- Playback Controls -->
                            <HBox alignment="CENTER_LEFT" spacing="10">

                                <Button fx:id="shuffleButton"
                                        text="⇄"
                                        onAction="#handleShuffle"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button text="⏮"
                                        onAction="#handlePrevious"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button fx:id="playPauseButton"
                                        text="▶"
                                        onAction="#handlePlayPause"
                                        styleClass="player-btn-main"
                                        prefWidth="64" prefHeight="56"
                                        style="-fx-font-size: 22px;" />

                                <Button text="⏭"
                                        onAction="#handleNext"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button fx:id="loopButton"
                                        text="↻"
                                        onAction="#handleLoop"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 22px;" />

                                <Region prefWidth="16" />

                                <Button fx:id="likeButton"
                                        text="♡"
                                        onAction="#handleLike"
                                        styleClass="player-btn-like"
                                        prefWidth="52" prefHeight="44" />

                                <Button fx:id="addToPlaylistButton"
                                        text="+"
                                        onAction="#handleAddToPlaylist"
                                        styleClass="btn-accent-soft"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 22px;" />

                            </HBox>

                        </children>
                    </VBox>

                        </children>
                    </HBox>
                </children>
            </HBox>

        </children>
    </VBox>

</StackPane>
