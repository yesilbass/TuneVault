<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.mainmenu.MainMenuController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    maxWidth="Infinity" maxHeight="Infinity" styleClass="home-root-scroll">
            <VBox fx:id="menuContent" spacing="18" styleClass="page-content home-center-fill"
                  maxWidth="Infinity"
                  style="-fx-padding: 16 32 12 32;">

                <!-- Greeting + vibe (stats live in footer) -->
                <VBox fx:id="homeHeroSection" spacing="8" styleClass="home-hero">
                    <Label fx:id="homeGreetingLabel" text="Welcome back" styleClass="heading-2xl"/>
                    <Label fx:id="homeVibeLabel" wrapText="true" maxWidth="Infinity"
                           managed="false" visible="false"/>
                    <Label fx:id="homeVibeSubLabel" wrapText="true" maxWidth="Infinity"
                           managed="false" visible="false" styleClass="caption"/>
                </VBox>

                <!-- Playlists first: 5 tiles per row (TilePane) -->
                <VBox fx:id="homeLibrariesSection" spacing="12" styleClass="home-libraries" VBox.vgrow="NEVER">
                    <VBox spacing="4">
                        <Label text="Jump back in" styleClass="heading-md"/>
                        <Label text="Up to five playlists per row — your full library stays in the left column."
                               styleClass="caption" wrapText="true" maxWidth="Infinity"/>
                    </VBox>
                    <TilePane fx:id="playlistChipsContainer" styleClass="home-playlist-grid"
                              hgap="12" vgap="12" prefColumns="5" tileAlignment="TOP_LEFT"/>
                    <Label fx:id="noPlaylistsHint" managed="false" visible="false"
                           text="Create a playlist from Library to see it here."
                           styleClass="caption"/>
                </VBox>

                <!-- Suggestions: fixed band height so the page scrolls under the top bar instead of stretching -->
                <HBox fx:id="homeFeedRow" spacing="20" alignment="TOP_LEFT" fillHeight="true"
                       minHeight="220" prefHeight="380" maxHeight="480">
                    <VBox fx:id="forYouFeedCard" spacing="12" styleClass="card home-feed-card" HBox.hgrow="ALWAYS"
                          minWidth="280" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                        <VBox spacing="4" VBox.vgrow="NEVER">
                            <Label text="Picked for you" styleClass="heading-md"/>
                            <Label text="Five songs picked from your taste profile" styleClass="caption"/>
                        </VBox>
                        <ListView fx:id="forYouListView" minHeight="160" maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <VBox fx:id="freshTracksFeedCard" spacing="12" styleClass="card home-feed-card" HBox.hgrow="ALWAYS"
                          minWidth="280" maxHeight="Infinity" VBox.vgrow="ALWAYS">
                        <VBox spacing="4" VBox.vgrow="NEVER">
                            <Label text="Artist shortcuts" styleClass="heading-md"/>
                            <Label text="Same names as your chart — jump into profiles." styleClass="caption"/>
                        </VBox>
                        <ListView fx:id="freshTracksListView" minHeight="160" maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </HBox>

                <!-- Today: same metric as charts, calendar day only (DB server date) -->
                <VBox fx:id="homeTodaySection" spacing="16" styleClass="home-charts-section" VBox.vgrow="NEVER">
                    <VBox spacing="4">
                        <Label text="TODAY" styleClass="home-charts-eyebrow"/>
                        <Label text="Listening time since midnight (server date). Left: tracks · right: artists."
                               wrapText="true" styleClass="caption" maxWidth="920"/>
                    </VBox>
                    <FlowPane fx:id="homeTodayFlow" hgap="18" vgap="18" styleClass="home-charts-flow">
                        <VBox fx:id="homeTodayTracksHost" spacing="0" styleClass="home-charts-card home-charts-card-tracks"
                              minWidth="300" prefWidth="520"/>
                        <VBox fx:id="homeTodayArtistsHost" spacing="0" styleClass="home-charts-card home-charts-card-artists"
                              minWidth="300" prefWidth="520"/>
                    </FlowPane>
                </VBox>

                <!-- Charts -->
                <VBox fx:id="homeChartsSection" spacing="16" styleClass="home-charts-section home-charts-section-follows" VBox.vgrow="NEVER">
                    <VBox spacing="4">
                        <Label text="YOUR CHARTS" styleClass="home-charts-eyebrow"/>
                        <Label text="All sessions combined, all time. Left: tracks · right: artists."
                               wrapText="true" styleClass="caption" maxWidth="920"/>
                    </VBox>
                    <FlowPane fx:id="homeChartsFlow" hgap="18" vgap="18" styleClass="home-charts-flow">
                        <VBox fx:id="homeTopSongsHost" spacing="0" styleClass="home-charts-card home-charts-card-tracks"
                              minWidth="300" prefWidth="520"/>
                        <VBox fx:id="homeTopArtistsHost" spacing="0" styleClass="home-charts-card home-charts-card-artists"
                              minWidth="300" prefWidth="520"/>
                    </FlowPane>
                </VBox>

                <!-- Library stats -->
                <HBox fx:id="homeStatsFooter" alignment="CENTER_LEFT" styleClass="home-stats-footer" VBox.vgrow="NEVER">
                    <Label fx:id="homeStatsLabel" text="" styleClass="body-sm"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
