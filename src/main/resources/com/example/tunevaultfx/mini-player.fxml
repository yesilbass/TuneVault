<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.controllers.MiniPlayerController"
            prefHeight="128"
            style="-fx-background-color: rgba(2, 6, 23, 0.98); -fx-padding: 16 28 16 28; -fx-border-color: rgba(255,255,255,0.06) transparent transparent transparent; -fx-border-width: 1 0 0 0;">

    <left>
        <VBox spacing="6"
              alignment="CENTER_LEFT"
              prefWidth="250"
              minWidth="250"
              maxWidth="250"
              BorderPane.alignment="CENTER_LEFT">
            <children>
                <Label fx:id="miniSongLabel"
                       text="No song playing"
                       wrapText="true"
                       maxWidth="240"
                       onMouseClicked="#handleOpenNowPlaying"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />

                <Label fx:id="miniArtistLabel"
                       text=""
                       wrapText="true"
                       maxWidth="240"
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;" />

                <Hyperlink fx:id="miniPlaylistLink"
                           text=""
                           onAction="#handleOpenCurrentPlaylist"
                           maxWidth="240"
                           style="-fx-text-fill: #60a5fa; -fx-font-size: 11px; -fx-border-color: transparent; -fx-padding: 0;" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <children>
                <VBox alignment="CENTER" spacing="10" maxWidth="760" prefWidth="760">
                    <children>
                        <Slider fx:id="miniProgressSlider"
                                prefWidth="700"
                                maxWidth="700" />

                        <HBox alignment="CENTER" spacing="14">
                            <children>
                                <Button fx:id="miniShuffleButton"
                                        text="🔀"
                                        onAction="#handleMiniShuffle"
                                        prefWidth="52"
                                        prefHeight="42"
                                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                <Button text="⏮"
                                        onAction="#handleMiniPrevious"
                                        prefWidth="52"
                                        prefHeight="42"
                                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                <Button fx:id="miniPlayPauseButton"
                                        text="▶"
                                        onAction="#handleMiniPlayPause"
                                        prefWidth="62"
                                        prefHeight="52"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 26;" />

                                <Button text="⏭"
                                        onAction="#handleMiniNext"
                                        prefWidth="52"
                                        prefHeight="42"
                                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                <Button fx:id="miniLoopButton"
                                        text="↻"
                                        onAction="#handleMiniLoop"
                                        prefWidth="52"
                                        prefHeight="42"
                                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                <Region prefWidth="8" />

                                <Button fx:id="miniLikeButton"
                                        text="♡"
                                        onAction="#handleMiniLike"
                                        prefWidth="52"
                                        prefHeight="42"
                                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 21;" />
                            </children>
                        </HBox>

                        <Label fx:id="miniTimeLabel"
                               text="0:00 / 0:00"
                               style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>

</BorderPane>