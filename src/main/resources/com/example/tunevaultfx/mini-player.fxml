<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  Root is VBox so the progress slider can span the FULL width of the bar
  (left of song info all the way to the right edge), exactly like Spotify.
  All fx:id's match MiniPlayerController exactly.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.tunevaultfx.musicplayer.controller.MiniPlayerController"
      prefHeight="96"
      style="-fx-background-color: #060510;
             -fx-border-color: rgba(255,255,255,0.07) transparent transparent transparent;
             -fx-border-width: 1 0 0 0;">

    <!-- ── Full-width progress slider ─────────────── -->
    <Slider fx:id="miniProgressSlider"
            maxWidth="Infinity"
            VBox.vgrow="NEVER"
            style="-fx-padding: 0; -fx-background-color: transparent;" />

    <!-- ── Main row ──────────────────────────────── -->
    <HBox VBox.vgrow="ALWAYS" alignment="CENTER">

        <!-- LEFT: Album art + Song info (270px) -->
        <HBox prefWidth="270" minWidth="270" maxWidth="270"
              spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 0 0 0 20;">

            <!-- Album art placeholder -->
            <StackPane prefWidth="46" prefHeight="46" minWidth="46" minHeight="46"
                       onMouseClicked="#handleOpenNowPlaying"
                       style="-fx-background-color: linear-gradient(to bottom right, #2d1f6e, #1a0b3c);
                              -fx-background-radius: 10;
                              -fx-border-color: rgba(139,92,246,0.22);
                              -fx-border-radius: 10;
                              -fx-border-width: 1;
                              -fx-cursor: hand;">
                <Label text="♫"
                       style="-fx-font-size: 20px; -fx-text-fill: rgba(167,139,250,0.5);" />
            </StackPane>

            <!-- Text info -->
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label fx:id="miniSongLabel"
                       text="No song playing"
                       maxWidth="180"
                       wrapText="false"
                       onMouseClicked="#handleOpenNowPlaying"
                       style="-fx-text-fill: #ffffff;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-cursor: hand;" />
                <Hyperlink fx:id="miniArtistLink"
                           text=""
                           onAction="#handleOpenArtistProfile"
                           style="-fx-text-fill: #52525b;
                                  -fx-font-size: 12px;
                                  -fx-border-color: transparent;
                                  -fx-padding: 0;" />
                <Hyperlink fx:id="miniPlaylistLink"
                           text=""
                           onAction="#handleOpenCurrentPlaylist"
                           maxWidth="180"
                           style="-fx-text-fill: #3d3d5c;
                                  -fx-font-size: 11px;
                                  -fx-border-color: transparent;
                                  -fx-padding: 0;" />
            </VBox>
        </HBox>

        <!-- CENTER: Playback controls (fills remaining space) -->
        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
            <HBox spacing="6" alignment="CENTER">

                <!-- Shuffle (⇄ is safe Unicode, not emoji) -->
                <Button fx:id="miniShuffleButton"
                        text="⇄"
                        onAction="#handleMiniShuffle"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #3d3d5c;
                               -fx-font-size: 17px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

                <!-- Previous -->
                <Button text="⏮"
                        onAction="#handleMiniPrevious"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #71717a;
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

                <!-- Play / Pause — white circle, prominent -->
                <Button fx:id="miniPlayPauseButton"
                        text="▶"
                        onAction="#handleMiniPlayPause"
                        prefWidth="60" prefHeight="46"
                        style="-fx-background-color: #ffffff;
                               -fx-text-fill: #060510;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 23;
                               -fx-effect: dropshadow(gaussian,rgba(255,255,255,0.18),8,0,0,2);" />

                <!-- Next -->
                <Button text="⏭"
                        onAction="#handleMiniNext"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #71717a;
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

                <!-- Loop (↻ renders fine) -->
                <Button fx:id="miniLoopButton"
                        text="↻"
                        onAction="#handleMiniLoop"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #3d3d5c;
                               -fx-font-size: 19px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

                <Region prefWidth="20" />

                <!-- Like -->
                <Button fx:id="miniLikeButton"
                        text="♡"
                        onAction="#handleMiniLike"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #3d3d5c;
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

                <!-- Add to playlist -->
                <Button fx:id="miniAddButton"
                        text="+"
                        onAction="#handleMiniAddToPlaylist"
                        prefWidth="60" prefHeight="36"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #3d3d5c;
                               -fx-font-size: 20px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 18;" />

            </HBox>
        </StackPane>

        <!-- RIGHT: Time label (160px) -->
        <VBox prefWidth="160" minWidth="160" maxWidth="160"
              alignment="CENTER_RIGHT"
              style="-fx-padding: 0 24 0 0;">
            <Label fx:id="miniTimeLabel"
                   text="0:00 / 0:00"
                   style="-fx-text-fill: #3d3d5c; -fx-font-size: 12px;" />
        </VBox>

    </HBox>
</VBox>
