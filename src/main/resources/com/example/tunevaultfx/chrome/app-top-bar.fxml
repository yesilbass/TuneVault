<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:id="topBarRoot"
      fx:controller="com.example.tunevaultfx.chrome.AppTopBarController"
      styleClass="app-top-bar"
      alignment="CENTER_LEFT"
      spacing="12">

    <padding>
        <Insets top="10" right="28" bottom="10" left="28"/>
    </padding>

    <!-- Brand (same row as search); click → home -->
    <HBox fx:id="topBarBrand" alignment="CENTER_LEFT" spacing="10" styleClass="top-bar-brand"
          onMouseClicked="#handleBrandClick">
        <StackPane styleClass="top-bar-logo-mark" prefWidth="34" prefHeight="34"
                   minWidth="34" minHeight="34">
            <Label text="&#9835;" styleClass="top-bar-logo-glyph"/>
        </StackPane>
        <VBox spacing="0">
            <Label text="TuneVault" styleClass="top-bar-brand-title"/>
            <Label text="Home" styleClass="top-bar-brand-tagline"/>
        </VBox>
    </HBox>

    <HBox spacing="6" alignment="CENTER_LEFT" styleClass="top-bar-nav-row">
        <Button fx:id="topBarBackButton" text="&#8592;" focusTraversable="false"
                onAction="#handleTopBarBack" styleClass="btn-ghost, top-bar-history-btn"/>
        <Button fx:id="topBarForwardButton" text="&#8594;" focusTraversable="false"
                onAction="#handleTopBarForward" styleClass="btn-ghost, top-bar-history-btn"/>
    </HBox>

    <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0">
        <HBox alignment="CENTER" spacing="6" pickOnBounds="false">
            <Button fx:id="topBarHomeButton" onAction="#handleHomeClick"
                    styleClass="top-bar-home-btn"
                    contentDisplay="GRAPHIC_ONLY" focusTraversable="false"
                    mnemonicParsing="false"
                    prefWidth="40" prefHeight="40" minWidth="40" minHeight="40">
                <graphic>
                    <Label text="⌂" styleClass="top-bar-home-glyph"/>
                </graphic>
            </Button>
            <StackPane minWidth="200" maxWidth="560" prefWidth="400" HBox.hgrow="ALWAYS">
                <TextField fx:id="globalSearchField"
                           promptText="What do you want to play?"
                           styleClass="top-bar-search-field"
                           maxWidth="Infinity"
                           prefHeight="40"
                           StackPane.alignment="CENTER_LEFT"/>
                <Button fx:id="searchInlineClearButton" text="✕"
                        onAction="#handleInlineSearchClear"
                        styleClass="top-bar-search-inline-clear"
                        focusTraversable="false"
                        mnemonicParsing="false"
                        prefWidth="32" minWidth="32" maxWidth="32"
                        prefHeight="32" minHeight="32" maxHeight="32"
                        StackPane.alignment="CENTER_RIGHT"/>
            </StackPane>
            <!-- Icons only: highlights / genre profile -->
            <Button fx:id="wrappedQuickBtn" onAction="#handleGoWrapped"
                    styleClass="top-bar-discovery-icon-btn" contentDisplay="GRAPHIC_ONLY"
                    focusTraversable="false" prefWidth="40" prefHeight="40" minWidth="40" minHeight="40">
                <graphic>
                    <Label text="✦" styleClass="top-bar-discovery-glyph top-bar-discovery-glyph-wrapped"/>
                </graphic>
            </Button>
            <Button fx:id="genreQuizQuickBtn" onAction="#handleGoGenreQuiz"
                    styleClass="top-bar-discovery-icon-btn" contentDisplay="GRAPHIC_ONLY"
                    focusTraversable="false" prefWidth="40" prefHeight="40" minWidth="40" minHeight="40">
                <graphic>
                    <Label text="◎" styleClass="top-bar-discovery-glyph"/>
                </graphic>
            </Button>
        </HBox>
    </StackPane>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="themeToggleBtn" text="Light mode" onAction="#toggleTheme"
                styleClass="top-bar-theme-btn" focusTraversable="false"/>
        <Button fx:id="accountMenuBtn" text="Account ▾" onAction="#handleAccountMenu"
                styleClass="top-bar-theme-btn, top-bar-account-menu" focusTraversable="false"/>
        <Button text="Log out" onAction="#handleLogout" styleClass="top-bar-logout-btn"
                focusTraversable="false"/>
    </HBox>
</HBox>
