<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
            <Button text="← Back"
                    onAction="#handleBackToMenu"
                    styleClass="btn-nav"/>

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🎵" style="-fx-font-size: 20px;"/>
                    <Label text="Playlists" styleClass="heading-xl"/>
                </HBox>
            </StackPane>

            <Region prefWidth="110"/>
        </HBox>
    </top>

    <!-- ── CENTER: Scrollable two-column layout ──── -->
    <center>
        <StackPane style="-fx-padding: 16 32 16 32;">

            <!-- Main scrollable content -->
            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED">
                <content>
                    <HBox fx:id="contentRow" spacing="20" alignment="TOP_LEFT" style="-fx-padding: 0 0 24 0;">

                        <!-- ── LEFT: Playlist list ──────────── -->
                        <VBox fx:id="playlistSidebarCard" spacing="16"
                              minWidth="280" prefWidth="280" maxWidth="280"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="Your Playlists" styleClass="heading-md"/>
                            </HBox>

                            <ListView fx:id="playlistListView" prefHeight="380"/>

                            <VBox spacing="8">
                                <Button text="+ New Playlist"
                                        onAction="#handleCreatePlaylist"
                                        maxWidth="Infinity"
                                        styleClass="btn-primary"/>

                                <Button text="Delete Playlist"
                                        onAction="#handleDeletePlaylist"
                                        maxWidth="Infinity"
                                        styleClass="btn-danger"/>
                            </VBox>
                        </VBox>

                        <!-- ── RIGHT: Content ──────────────── -->
                        <VBox spacing="18" HBox.hgrow="ALWAYS">

                            <!-- Playlist songs card -->
                            <VBox fx:id="playlistSongsCard" spacing="14" styleClass="card">

                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label fx:id="selectedPlaylistLabel"
                                               text="No playlist selected"
                                               styleClass="heading-lg"/>
                                        <HBox spacing="16" alignment="CENTER_LEFT">
                                            <Label fx:id="songCountLabel"
                                                   text="Songs: 0"
                                                   styleClass="body-sm, text-accent"/>
                                            <Label fx:id="totalDurationLabel"
                                                   text="Duration: 0:00"
                                                   styleClass="body-sm, text-accent"/>
                                        </HBox>
                                    </VBox>
                                    <Button text="+ Add Song"
                                            onAction="#handleShowSearchSongs"
                                            styleClass="btn-accent-soft"/>
                                </HBox>

                                <Separator/>

                                <ListView fx:id="playlistSongsListView" prefHeight="260"/>
                            </VBox>

                            <!-- Suggestions card (hidden until populated) -->
                            <VBox fx:id="suggestionsSection"
                                  spacing="14"
                                  visible="false"
                                  managed="false"
                                  styleClass="card-glow">

                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Suggested For You" styleClass="heading-md"/>
                                        <Label fx:id="suggestionSubtitleLabel"
                                               text="Based on this playlist and your listening history"
                                               styleClass="caption"/>
                                    </VBox>
                                    <Label text="✦ Smart Picks" styleClass="badge, badge-accent"/>
                                </HBox>

                                <Separator/>

                                <ListView fx:id="suggestedSongsListView"
                                          prefHeight="268"
                                          maxHeight="268"
                                          fixedCellSize="66"/>
                            </VBox>

                        </VBox>
                    </HBox>
                </content>
            </ScrollPane>

            <!-- Floating search panel (top-right overlay) -->
            <VBox fx:id="searchSongsPanel"
                  visible="false"
                  managed="false"
                  maxWidth="340" minWidth="340" prefWidth="340"
                  spacing="14"
                  StackPane.alignment="TOP_RIGHT"
                  translateX="-8"
                  styleClass="card-elevated">
                <children>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Add Songs" styleClass="heading-md"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✕"
                                onAction="#handleHideSearchSongs"
                                prefWidth="36" prefHeight="36"
                                styleClass="btn-danger"/>
                    </HBox>

                    <TextField fx:id="searchSongsField"
                               promptText="Title, artist, album or genre…"
                               prefHeight="42"/>

                    <Label text="Double-click a result to open song details."
                           wrapText="true"
                           styleClass="caption"/>

                    <ListView fx:id="searchResultsListView"
                              VBox.vgrow="ALWAYS"
                              prefHeight="380"/>

                </children>
            </VBox>

        </StackPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml"/>
    </bottom>

</BorderPane>
