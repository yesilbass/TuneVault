<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="1280.0"
            prefHeight="760.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 20 24 16 24;">
            <children>
                <Label text="Playlists"
                       style="-fx-text-fill: white; -fx-font-size: 30px; -fx-font-weight: bold;" />
                <Button text="Back to Menu"
                        onAction="#handleBackToMenu"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 18;"
                        prefWidth="135.0"
                        prefHeight="38.0" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 10 24 18 24;">
            <children>

                <!-- Main two-column layout -->
                <HBox spacing="24.0" alignment="TOP_LEFT">
                    <children>

                        <!-- Left card -->
                        <VBox spacing="16.0"
                              minWidth="340.0"
                              prefWidth="340.0"
                              maxWidth="340.0"
                              style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 24;">
                            <children>
                                <Label text="Your Playlists"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                                <ListView fx:id="playlistListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="460.0"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />

                                <HBox spacing="14.0" alignment="CENTER">
                                    <children>
                                        <Button text="Create Playlist"
                                                onAction="#handleCreatePlaylist"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="Infinity"
                                                prefHeight="44.0"
                                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" />

                                        <Button text="Delete Playlist"
                                                onAction="#handleDeletePlaylist"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="Infinity"
                                                prefHeight="44.0"
                                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Center card -->
                        <VBox spacing="16.0"
                              HBox.hgrow="ALWAYS"
                              minWidth="520.0"
                              prefWidth="720.0"
                              style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 24;">
                            <children>
                                <Label fx:id="selectedPlaylistLabel"
                                       text="No playlist selected"
                                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />

                                <HBox spacing="18.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="songCountLabel"
                                               text="Songs: 0"
                                               style="-fx-font-size: 16px; -fx-text-fill: #334155;" />
                                        <Label fx:id="totalDurationLabel"
                                               text="Duration: 0:00"
                                               style="-fx-font-size: 16px; -fx-text-fill: #334155;" />
                                    </children>
                                </HBox>

                                <ListView fx:id="playlistSongsListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="470.0"
                                          style="-fx-background-radius: 12; -fx-border-radius: 12;" />

                                <HBox spacing="14.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="Add Song"
                                                onAction="#handleShowSearchSongs"
                                                prefWidth="160.0"
                                                prefHeight="44.0"
                                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" />

                                        <Button text="Remove Song"
                                                onAction="#handleRemoveSong"
                                                prefWidth="170.0"
                                                prefHeight="44.0"
                                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Overlay search panel -->
                <VBox fx:id="searchSongsPanel"
                      visible="false"
                      managed="false"
                      maxWidth="330.0"
                      minWidth="330.0"
                      prefWidth="330.0"
                      spacing="14.0"
                      StackPane.alignment="TOP_RIGHT"
                      translateX="-8.0"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 24; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 20, 0.2, 0, 6);">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Search Songs"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="X"
                                        onAction="#handleHideSearchSongs"
                                        prefWidth="48.0"
                                        prefHeight="48.0"
                                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 24;" />
                            </children>
                        </HBox>

                        <Label text="Select one or more songs to add"
                               style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />

                        <TextField fx:id="searchSongsField"
                                   promptText="Search by title, artist, or album"
                                   prefHeight="42.0"
                                   style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1;" />

                        <ListView fx:id="searchResultsListView"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="420.0"
                                  style="-fx-background-radius: 12; -fx-border-radius: 12;" />

                        <Button text="Add Selected"
                                onAction="#handleAddSelectedSearchSong"
                                prefWidth="170.0"
                                prefHeight="44.0"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 22;" />
                    </children>
                </VBox>

            </children>
        </StackPane>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>