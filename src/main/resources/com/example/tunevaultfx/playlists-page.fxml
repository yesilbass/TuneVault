<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.playlist.PlaylistsPageController"
            prefWidth="900" prefHeight="700"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20;">
            <Button text="Back to Menu"
                    prefWidth="120" prefHeight="38"
                    onAction="#handleBackToMenu"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 20;" />

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <Label text="Playlists"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
            </StackPane>

            <Region prefWidth="120" />
        </HBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="18" style="-fx-padding: 20;">
            <children>

                <VBox spacing="12"
                      prefWidth="250"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <children>
                        <Label text="Your Playlists"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;" />

                        <ListView fx:id="playlistListView" prefHeight="420" />

                        <HBox spacing="8">
                            <Button text="Create Playlist"
                                    onAction="#handleCreatePlaylist"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20;" />

                            <Button text="Delete Playlist"
                                    onAction="#handleDeletePlaylist"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 20;" />
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="12"
                      prefWidth="460"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <children>
                        <Label fx:id="selectedPlaylistLabel"
                               text="No playlist selected"
                               style="-fx-font-size: 24px; -fx-font-weight: bold;" />

                        <HBox spacing="16">
                            <Label fx:id="songCountLabel"
                                   text="Songs: 0"
                                   style="-fx-font-size: 16px;" />
                            <Label fx:id="totalDurationLabel"
                                   text="Duration: 0:00"
                                   style="-fx-font-size: 16px;" />
                        </HBox>

                        <ListView fx:id="playlistSongsListView" prefHeight="420" />

                        <HBox spacing="8">
                            <Button text="Add Song"
                                    onAction="#handleShowSearchSongs"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20;" />

                            <Button text="Remove Song"
                                    onAction="#handleRemoveSong"
                                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-background-radius: 20;" />
                        </HBox>
                    </children>
                </VBox>

                <VBox fx:id="searchSongsPanel"
                      spacing="10"
                      prefWidth="300"
                      visible="false"
                      managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 18;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Search Songs"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                                <Region HBox.hgrow="ALWAYS" />

                                <Button text="X"
                                        onAction="#handleHideSearchSongs"
                                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;"
                                        prefWidth="40" />
                            </children>
                        </HBox>

                        <Label text="Select one or more songs to add"
                               style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />

                        <TextField fx:id="searchSongsField"
                                   promptText="Search by song, artist, or album" />

                        <ListView fx:id="searchResultsListView" prefHeight="360" />

                        <HBox spacing="8">
                            <Button text="Add Selected"
                                    onAction="#handleAddSelectedSearchSong"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 20;" />
                        </HBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>