<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.musicplayer.controller.QueuePanelController"
           fx:id="queueOverlayRoot"
           id="queuePanelOverlay"
           visible="false"
           managed="false"
           pickOnBounds="true">

    <!-- Backdrop -->
    <StackPane fx:id="backdropPane"
               styleClass="overlay-backdrop"
               onMouseClicked="#handleBackdropClick" />

    <!-- Queue panel -->
    <VBox fx:id="queuePanel"
          styleClass="queue-panel"
          maxWidth="420" prefWidth="420"
          StackPane.alignment="CENTER_RIGHT"
          onMouseClicked="#handleConsumeClick">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 24 16 24;
                     -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                     -fx-border-width: 0 0 1 0;">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="UP NEXT" styleClass="overline, text-accent" />
                <Label fx:id="queueCountLabel" text="Queue"
                       styleClass="heading-md" style="-fx-font-size: 17px;" />
            </VBox>
            <Button fx:id="clearQueueButton" text="Clear"
                    onAction="#handleClearQueue"
                    styleClass="btn-danger" prefHeight="32" />
            <Button text="✕" onAction="#handleClose"
                    styleClass="btn-icon" prefWidth="36" prefHeight="36" />
        </HBox>

        <!-- Now Playing -->
        <VBox fx:id="nowPlayingSection" spacing="6"
              style="-fx-padding: 16 24 12 24;">
            <Label text="NOW PLAYING" styleClass="overline" />
            <HBox fx:id="nowPlayingRow" spacing="12" alignment="CENTER_LEFT"
                  styleClass="now-playing-row">
                <StackPane prefWidth="40" prefHeight="40" minWidth="40"
                           styleClass="album-art-mini"
                           style="-fx-background-radius: 10; -fx-border-radius: 10;">
                    <Label text="♫"
                           style="-fx-font-size: 16px; -fx-text-fill: rgba(196,181,253,0.6);" />
                </StackPane>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="nowPlayingTitle" text="—"
                           styleClass="heading-sm" style="-fx-font-size: 13px;" />
                    <Label fx:id="nowPlayingArtist" text=""
                           styleClass="caption" />
                </VBox>
            </HBox>
        </VBox>

        <Separator />

        <!-- Single unified queue list -->
        <VBox spacing="6" VBox.vgrow="ALWAYS"
              style="-fx-padding: 12 0 16 0;">
            <HBox alignment="CENTER_LEFT" spacing="8"
                  style="-fx-padding: 0 24 6 24;">
                <Label text="QUEUE" styleClass="overline" />
                <Label fx:id="queueBadge" text="" styleClass="badge-count" />
            </HBox>
            <ListView fx:id="queueListView"
                      VBox.vgrow="ALWAYS"
                      style="-fx-padding: 0 10 0 10;" />
        </VBox>

    </VBox>
</StackPane>
