<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="450.0" prefWidth="650.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.controllers.auth.ForgotPasswordPageController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <children>
        <VBox alignment="CENTER" spacing="18"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label text="Reset Password"
                       style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />

                <VBox spacing="12" maxWidth="380"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 25;">
                    <children>
                        <Label text="Email"
                               style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   prefHeight="40.0" />

                        <Label text="New Password"
                               style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Enter new password"
                                       prefHeight="40.0" />

                        <Label text="Confirm New Password"
                               style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Confirm new password"
                                       prefHeight="40.0" />

                        <Button text="Update Password"
                                onAction="#handleSubmit"
                                prefHeight="40.0"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

                        <Button text="Back to Login"
                                onAction="#handleBackToLogin"
                                prefHeight="40.0"
                                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" />

                        <Label fx:id="statusLabel"
                               text=""
                               wrapText="true"
                               style="-fx-text-fill: #dc2626; -fx-font-size: 12px;" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>