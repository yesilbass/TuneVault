<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.auth.ForgotPasswordPageController"
           prefWidth="800.0"
           prefHeight="540.0"
           style="-fx-background-color: linear-gradient(to bottom right, #090912, #0f0f1e);">

    <VBox alignment="CENTER" spacing="0">
        <children>

            <!-- Header -->
            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 28 0;">
                <StackPane prefWidth="64" prefHeight="64" maxWidth="64" maxHeight="64"
                           style="-fx-background-color: rgba(139,92,246,0.15);
                                  -fx-background-radius: 32;
                                  -fx-border-color: rgba(139,92,246,0.3);
                                  -fx-border-radius: 32;
                                  -fx-border-width: 1;">
                    <Label text="🔑"
                           style="-fx-font-size: 26px;" />
                </StackPane>
                <Label text="Reset Password"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                <Label text="Enter your email and choose a new password"
                       style="-fx-font-size: 13px; -fx-text-fill: #52525b;" />
            </VBox>

            <!-- Card -->
            <VBox spacing="18" maxWidth="380"
                  style="-fx-background-color: #14141e;
                         -fx-background-radius: 22;
                         -fx-border-color: rgba(255,255,255,0.08);
                         -fx-border-radius: 22;
                         -fx-border-width: 1;
                         -fx-padding: 32;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 28, 0, 0, 8);">
                <children>

                    <VBox spacing="6">
                        <Label text="EMAIL"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                        <TextField fx:id="emailField"
                                   promptText="your@email.com"
                                   prefHeight="44" />
                    </VBox>

                    <VBox spacing="6">
                        <Label text="NEW PASSWORD"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Create a new password"
                                       prefHeight="44" />
                    </VBox>

                    <VBox spacing="6">
                        <Label text="CONFIRM NEW PASSWORD"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Repeat new password"
                                       prefHeight="44" />
                    </VBox>

                    <VBox spacing="10" style="-fx-padding: 4 0 0 0;">
                        <Button text="Update Password"
                                onAction="#handleSubmit"
                                maxWidth="Infinity"
                                prefHeight="46"
                                style="-fx-background-color: #8b5cf6;
                                       -fx-text-fill: white;
                                       -fx-font-size: 15px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 13;
                                       -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.38), 12, 0, 0, 4);" />

                        <Button text="← Back to Login"
                                onAction="#handleBackToLogin"
                                maxWidth="Infinity"
                                prefHeight="42"
                                style="-fx-background-color: rgba(255,255,255,0.06);
                                       -fx-text-fill: #94a3b8;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 13;" />
                    </VBox>

                    <Label fx:id="statusLabel"
                           text=""
                           wrapText="true"
                           maxWidth="340"
                           style="-fx-text-fill: #f87171; -fx-font-size: 13px;" />

                </children>
            </VBox>

        </children>
    </VBox>

</StackPane>
