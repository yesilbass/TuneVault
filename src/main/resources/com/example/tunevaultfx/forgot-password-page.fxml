<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.auth.ForgotPasswordPageController"
           styleClass="auth-bg"
           prefWidth="960.0" prefHeight="600.0">

    <VBox alignment="CENTER" styleClass="auth-card" spacing="28"
          style="-fx-max-width: 420;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="14">
            <StackPane styleClass="icon-box,icon-box-violet"
                       prefWidth="64" prefHeight="64" maxWidth="64" maxHeight="64"
                       style="-fx-background-radius: 32; -fx-border-radius: 32;">
                <Label text="🔑" style="-fx-font-size: 26px;" />
            </StackPane>
            <Label text="Reset Password" styleClass="auth-brand" />
            <Label text="Enter your email and choose a new password" styleClass="auth-subtitle" />
        </VBox>

        <!-- Form fields -->
        <VBox spacing="14">
            <VBox spacing="8">
                <Label text="EMAIL" styleClass="field-label" />
                <TextField fx:id="emailField"
                           promptText="your@email.com"
                           prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <Label text="NEW PASSWORD" styleClass="field-label" />
                <PasswordField fx:id="newPasswordField"
                               promptText="Create a new password"
                               prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <Label text="CONFIRM NEW PASSWORD" styleClass="field-label" />
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Repeat new password"
                               prefHeight="46" />
            </VBox>
        </VBox>

        <!-- Actions -->
        <VBox spacing="10">
            <Button text="Update Password"
                    onAction="#handleSubmit"
                    defaultButton="true"
                    styleClass="btn-primary"
                    maxWidth="Infinity" prefHeight="46" />

            <Button text="← Back to Login"
                    onAction="#handleBackToLogin"
                    cancelButton="true"
                    styleClass="btn-secondary"
                    maxWidth="Infinity" prefHeight="46" />
        </VBox>

        <Label fx:id="statusLabel" text="" wrapText="true"
               style="-fx-max-width: 380;" />

    </VBox>

</StackPane>
