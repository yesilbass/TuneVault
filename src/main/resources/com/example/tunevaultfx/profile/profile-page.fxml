<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.profile.ProfilePageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="profile-scroll">
            <content>
                <VBox fx:id="profilePageRoot" spacing="0" maxWidth="Infinity"
                      styleClass="profile-page-root">
                    <padding>
                        <Insets top="32" right="44" bottom="56" left="44"/>
                    </padding>

                    <VBox spacing="10" styleClass="profile-page-hero">
                        <Label text="Profile" styleClass="profile-page-title"/>
                        <Label text="Avatar, listening stats, genre taste, and follows from this account."
                               wrapText="true" maxWidth="Infinity" styleClass="profile-page-lede"/>
                    </VBox>

                    <Region prefHeight="32"/>

                    <VBox spacing="22" styleClass="profile-header-shell">
                        <padding>
                            <Insets top="28" right="32" bottom="32" left="32"/>
                        </padding>
                        <HBox spacing="28" alignment="TOP_LEFT" styleClass="profile-identity-row">
                            <StackPane styleClass="profile-avatar" prefWidth="128" minWidth="128" maxWidth="128"
                                       prefHeight="128" minHeight="128" maxHeight="128">
                                <ImageView fx:id="profileAvatarImage" fitWidth="128" fitHeight="128"
                                           pickOnBounds="true" preserveRatio="true" smooth="true" cache="true"/>
                                <Label fx:id="profileAvatarInitial" text="?"
                                       styleClass="profile-avatar-initial" mouseTransparent="true"/>
                                <StackPane alignment="BOTTOM_RIGHT" pickOnBounds="false" mouseTransparent="false">
                                    <HBox spacing="8" pickOnBounds="false" style="-fx-padding: 0 4 4 0;">
                                        <Button fx:id="changeAvatarButton" text="Photo"
                                                styleClass="btn-ghost, profile-media-chip-sm"
                                                focusTraversable="false"/>
                                        <Button fx:id="removeAvatarButton" text="Clear"
                                                styleClass="btn-ghost, profile-media-chip-sm"
                                                focusTraversable="false"/>
                                    </HBox>
                                </StackPane>
                            </StackPane>
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <HBox spacing="14" alignment="CENTER_LEFT">
                                    <Label fx:id="profileDisplayName" text="Display name"
                                           styleClass="profile-display-name" wrapText="true"
                                           HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="followUserButton" text="Follow"
                                            managed="false" visible="false"
                                            styleClass="btn-primary" prefHeight="44" minHeight="44"
                                            focusTraversable="false"/>
                                </HBox>
                                <Label fx:id="profileHandleLabel" text="@username" styleClass="profile-handle"/>
                                <Label fx:id="profileEmailLabel" text="email" styleClass="profile-email"
                                       wrapText="true"/>
                                <Label fx:id="profileAccountIdLabel" text="" styleClass="profile-account-meta"
                                       wrapText="true"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="profile-stat-row">
                            <VBox styleClass="profile-stat-tile" HBox.hgrow="ALWAYS">
                                <Label fx:id="statPlaylistsValue" text="0" styleClass="profile-stat-value"/>
                                <Label fx:id="statCaptionPlaylists" text="Playlists"
                                       styleClass="profile-stat-label"/>
                            </VBox>
                            <VBox styleClass="profile-stat-tile" HBox.hgrow="ALWAYS">
                                <Label fx:id="statSavedValue" text="0" styleClass="profile-stat-value"/>
                                <Label fx:id="statCaptionSaved" text="Saved songs"
                                       styleClass="profile-stat-label"/>
                            </VBox>
                            <VBox styleClass="profile-stat-tile" HBox.hgrow="ALWAYS">
                                <Label fx:id="statListeningValue" text="0" styleClass="profile-stat-value"/>
                                <Label fx:id="statListeningHint" text="Counted plays"
                                       styleClass="profile-stat-label"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <Region prefHeight="40"/>

                    <HBox spacing="44" alignment="TOP_LEFT" styleClass="profile-columns">
                        <VBox spacing="36" HBox.hgrow="ALWAYS" minWidth="340" styleClass="profile-column">
                            <VBox spacing="0">
                                <Label text="Following &amp; followers" styleClass="profile-section-title"/>
                                <VBox fx:id="socialSection" spacing="0" styleClass="card-elevated profile-detail-card">
                                    <padding>
                                        <Insets top="26" right="28" bottom="28" left="28"/>
                                    </padding>
                                    <Label text="Double-click a name to open their profile."
                                           wrapText="true" maxWidth="Infinity" styleClass="profile-card-caption"
                                           style="-fx-padding: 0 0 16 0;"/>
                                    <HBox spacing="20" alignment="TOP_LEFT">
                                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                                            <Label text="Following" styleClass="profile-card-heading"/>
                                            <ListView fx:id="followingListView" prefHeight="220" minHeight="180"
                                                      VBox.vgrow="SOMETIMES"/>
                                        </VBox>
                                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                                            <Label text="Followers" styleClass="profile-card-heading"/>
                                            <ListView fx:id="followersListView" prefHeight="220" minHeight="180"
                                                      VBox.vgrow="SOMETIMES"/>
                                        </VBox>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </VBox>

                        <VBox spacing="36" HBox.hgrow="ALWAYS" minWidth="340" styleClass="profile-column">
                            <VBox spacing="0">
                                <Label text="Taste &amp; discovery" styleClass="profile-section-title"/>
                                <VBox spacing="0" styleClass="card-elevated profile-detail-card">
                                    <padding>
                                        <Insets top="26" right="28" bottom="28" left="28"/>
                                    </padding>
                                    <Label text="Genre blend" styleClass="profile-card-heading"/>
                                    <Label text="Feeds recommendations, search ranking, and autoplay."
                                           wrapText="true" maxWidth="Infinity" styleClass="profile-card-caption"
                                           style="-fx-padding: 6 0 14 0;"/>
                                    <FlowPane fx:id="genreChipsFlow" hgap="10" vgap="10"
                                              styleClass="profile-genre-flow"/>
                                    <Label fx:id="genreSummaryLabel" wrapText="true" maxWidth="Infinity"
                                           styleClass="profile-genre-summary"/>
                                    <VBox fx:id="goToGenreQuizBlock" spacing="8" style="-fx-padding: 18 0 0 0;"
                                          visible="false" managed="false">
                                        <Button text="Take the genre quiz"
                                                onAction="#handleGoToGenreQuiz"
                                                styleClass="btn-primary" prefHeight="46" minHeight="46"
                                                wrapText="true" maxWidth="Infinity"/>
                                        <Label wrapText="true" maxWidth="Infinity" styleClass="profile-card-caption"
                                               text="A short quiz saves your blend so the app can lean into your style."/>
                                    </VBox>
                                    <VBox fx:id="clearGenreQuizBlock" spacing="8" style="-fx-padding: 18 0 0 0;"
                                          visible="false" managed="false">
                                        <Button fx:id="clearGenreQuizButton"
                                                text="Clear Find Your Genre from recommendations"
                                                onAction="#handleClearGenreQuiz"
                                                styleClass="btn-rose-soft" prefHeight="46" minHeight="46"
                                                wrapText="true" maxWidth="Infinity"/>
                                        <Label wrapText="true" maxWidth="Infinity" styleClass="profile-card-caption"
                                               text="Removes only quiz-saved taste data. Plays, playlists, and Wrapped stats stay."/>
                                    </VBox>
                                </VBox>
                            </VBox>

                            <VBox spacing="0">
                                <Label text="Listening activity" styleClass="profile-section-title"/>
                                <VBox spacing="0" styleClass="card-elevated profile-detail-card">
                                    <padding>
                                        <Insets top="26" right="28" bottom="28" left="28"/>
                                    </padding>
                                    <Label text="This device &amp; account" styleClass="profile-card-heading"/>
                                    <Label fx:id="listeningSummaryLabel" wrapText="true" maxWidth="Infinity"
                                           styleClass="profile-listening-body"
                                           style="-fx-padding: 10 0 0 0;"/>
                                    <Label text="Counts use the same play threshold as Wrapped."
                                           wrapText="true" maxWidth="Infinity" styleClass="profile-card-caption"
                                           style="-fx-padding: 14 0 0 0;"/>
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>
</BorderPane>
