<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.ArtistProfileController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>
    <!-- ── CENTER ────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox spacing="20" style="-fx-padding: 20 32 20 32;">
                    <children>

                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 4 0;">
                            <Button fx:id="backButton" text="Back"
                                    onAction="#handleBack"
                                    styleClass="btn-ghost"/>
                        </HBox>

                        <!-- Hero card -->
                        <HBox spacing="28" alignment="CENTER_LEFT" styleClass="hero-gradient">
                            <children>

                                <!-- Artist avatar (large initial) -->
                                <StackPane prefWidth="100" prefHeight="100"
                                           minWidth="100" minHeight="100"
                                           styleClass="artist-avatar">
                                    <Label text="♫"
                                           style="-fx-font-size: 42px; -fx-text-fill: rgba(255,255,255,0.5);"/>
                                </StackPane>

                                <!-- Artist info -->
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="ARTIST" styleClass="overline"/>
                                    <Label fx:id="artistNameLabel"
                                           text="Artist Name"
                                           styleClass="heading-xl"
                                           style="-fx-font-size: 38px;"/>
                                    <Label fx:id="artistSummaryLabel"
                                           text="Songs available: 0"
                                           styleClass="body-sm"/>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- Songs card -->
                        <VBox spacing="14" VBox.vgrow="ALWAYS" styleClass="card">
                            <children>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane styleClass="icon-box-sm, icon-box-violet">
                                        <Label text="♫" styleClass="text-accent"/>
                                    </StackPane>
                                    <Label text="Discography" styleClass="heading-lg"/>
                                    <Label text="Double-click to play · Right-click for more" styleClass="caption"/>
                                </HBox>

                                <Separator/>

                                <ListView fx:id="artistSongsListView"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="480"/>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
