<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.ArtistProfileController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="artist-profile-scroll">
            <content>
                <VBox spacing="24" styleClass="artist-profile-content" maxWidth="Infinity">
                    <children>

                        <VBox styleClass="artist-profile-hero" spacing="22" maxWidth="Infinity">
                            <children>
                                <HBox spacing="28" alignment="CENTER_LEFT" maxWidth="Infinity">
                                    <children>
                                        <StackPane styleClass="artist-avatar-xl">
                                            <children>
                                                <Label fx:id="artistAvatarInitialLabel" text="♫"
                                                       styleClass="artist-avatar-initial"/>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="14" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                            <children>
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label text="ARTIST" styleClass="artist-profile-kicker"/>
                                                        <Label text="PROFILE" styleClass="artist-profile-pill"/>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="artistNameLabel" text="Artist Name"
                                                       styleClass="artist-profile-name"
                                                       wrapText="true"
                                                       maxWidth="Infinity"/>
                                                <Label fx:id="artistSummaryLabel" text=""
                                                       styleClass="profile-hero-lede" wrapText="true"
                                                       managed="false" visible="false"/>
                                                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="artist-stats-row">
                                                    <children>
                                                        <VBox styleClass="profile-stat-block">
                                                            <children>
                                                                <Label fx:id="artistStatTracksLabel" text="—"
                                                                       styleClass="profile-stat-value"/>
                                                                <Label text="TRACKS" styleClass="profile-stat-caption"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox styleClass="profile-stat-block">
                                                            <children>
                                                                <Label fx:id="artistStatRuntimeLabel" text="—"
                                                                       styleClass="profile-stat-value"/>
                                                                <Label text="TOTAL RUNTIME" styleClass="profile-stat-caption"/>
                                                            </children>
                                                        </VBox>
                                                        <VBox styleClass="profile-stat-block">
                                                            <children>
                                                                <Label fx:id="artistStatAlbumsLabel" text="—"
                                                                       styleClass="profile-stat-value"/>
                                                                <Label text="ALBUMS" styleClass="profile-stat-caption"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox styleClass="artist-profile-toolbar" maxWidth="Infinity" alignment="CENTER_LEFT">
                                    <children>
                                        <Button fx:id="playDiscographyButton" text="Play"
                                                onAction="#handlePlayDiscography"
                                                styleClass="artist-action-primary"
                                                minHeight="44" prefHeight="44"
                                                focusTraversable="false"/>
                                        <Button fx:id="shuffleDiscographyButton" text="Shuffle"
                                                onAction="#handleShuffleDiscography"
                                                styleClass="artist-action-secondary"
                                                minHeight="44" prefHeight="44"
                                                focusTraversable="false"/>
                                        <Button fx:id="followArtistButton" text="Follow"
                                                onAction="#handleFollowArtist"
                                                styleClass="artist-action-secondary"
                                                minHeight="44" prefHeight="44"
                                                managed="false" visible="false"
                                                focusTraversable="false"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="SORT BY" styleClass="artist-sort-label"/>
                                        <ComboBox fx:id="sortComboBox" styleClass="combo-sort-profile"
                                                  prefWidth="210" focusTraversable="false"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="14" VBox.vgrow="ALWAYS" styleClass="artist-discography-card" maxWidth="Infinity">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <StackPane styleClass="artist-discography-icon">
                                            <children>
                                                <Label text="♫" styleClass="text-accent"/>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="3">
                                            <children>
                                                <Label text="Discography" styleClass="artist-section-title"/>
                                                <Label text="Hover for play · Double-click a row · Right-click for more"
                                                       styleClass="artist-section-subtitle"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <Separator/>
                                <HBox styleClass="tracklist-column-header" spacing="12" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="#" minWidth="36" styleClass="tracklist-col-label"/>
                                        <Label text="TITLE" styleClass="tracklist-col-label" HBox.hgrow="ALWAYS"/>
                                        <Label text="TIME" minWidth="52" styleClass="tracklist-col-label"/>
                                    </children>
                                </HBox>
                                <ListView fx:id="artistSongsListView"
                                          VBox.vgrow="ALWAYS"
                                          minHeight="420" prefHeight="640" maxHeight="Infinity"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
