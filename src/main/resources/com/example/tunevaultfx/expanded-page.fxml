<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.musicplayer.ExpandedPlayerController"
           fx:id="overlayRoot"
           id="expandedPlayerOverlay"
           visible="false"
           managed="false"
           pickOnBounds="true">

    <children>
        <StackPane fx:id="backdropPane"
                   onMouseClicked="#handleBackdropClick"
                   style="-fx-background-color: rgba(2, 6, 23, 0.62);" />

        <VBox fx:id="playerCard"
              alignment="CENTER"
              maxWidth="1040"
              prefWidth="1040"
              spacing="24"
              onMouseClicked="#handleConsumeClick"
              style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #eef2f7);
                     -fx-background-radius: 34;
                     -fx-padding: 24 38 34 38;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 32, 0.22, 0, 10);">
            <children>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="2">
                            <children>
                                <Label text="Now Playing"
                                       style="-fx-text-fill: #0f172a; -fx-font-size: 30px; -fx-font-weight: bold;" />
                                <Label text="Expanded player"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="✕"
                                onAction="#handleClose"
                                prefWidth="44"
                                prefHeight="44"
                                style="-fx-background-color: #e2e8f0;
                                       -fx-text-fill: #334155;
                                       -fx-font-size: 18px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 22;" />
                    </children>
                </HBox>

                <HBox alignment="TOP_CENTER" spacing="38">
                    <children>

                        <VBox alignment="CENTER" spacing="18" prefWidth="330">
                            <children>
                                <StackPane prefWidth="300" prefHeight="300"
                                           style="-fx-background-color: linear-gradient(to bottom right, #dbeafe, #bfdbfe);
                                                  -fx-background-radius: 30;
                                                  -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.12), 24, 0.2, 0, 8);">
                                    <children>
                                        <Label text="♪"
                                               style="-fx-font-size: 104px; -fx-text-fill: rgba(30,41,59,0.16); -fx-font-weight: bold;" />
                                    </children>
                                </StackPane>

                                <Label text="TuneVault Player"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 15px; -fx-font-weight: bold;" />
                            </children>
                        </VBox>

                        <VBox spacing="20" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="560">
                            <children>

                                <VBox spacing="10">
                                    <children>
                                        <Label text="CURRENT TRACK"
                                               style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-font-weight: bold;" />

                                        <Label fx:id="titleLabel"
                                               text="No song playing"
                                               wrapText="true"
                                               maxWidth="540"
                                               style="-fx-font-size: 44px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

                                        <Label fx:id="artistLabel"
                                               text=""
                                               wrapText="true"
                                               maxWidth="540"
                                               style="-fx-font-size: 24px; -fx-text-fill: #475569;" />

                                        <Label fx:id="albumLabel"
                                               text="Album: -"
                                               wrapText="true"
                                               maxWidth="540"
                                               style="-fx-font-size: 17px; -fx-text-fill: #64748b;" />
                                    </children>
                                </VBox>

                                <VBox spacing="12"
                                      style="-fx-background-color: rgba(255,255,255,0.9);
                                             -fx-background-radius: 22;
                                             -fx-padding: 18 18 16 18;
                                             -fx-border-color: #e2e8f0;
                                             -fx-border-radius: 22;">
                                    <children>
                                        <Slider fx:id="progressSlider"
                                                prefWidth="520"
                                                maxWidth="520" />

                                        <HBox alignment="CENTER">
                                            <children>
                                                <Label text="Playback Progress"
                                                       style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="timeLabel"
                                                       text="0:00 / 0:00"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <children>
                                        <Button fx:id="shuffleButton"
                                                text="🔀"
                                                onAction="#handleShuffle"
                                                prefWidth="70"
                                                prefHeight="42"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                        <Button text="⏮"
                                                onAction="#handlePrevious"
                                                prefWidth="62"
                                                prefHeight="42"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                        <Button fx:id="playPauseButton"
                                                text="▶"
                                                onAction="#handlePlayPause"
                                                prefWidth="62"
                                                prefHeight="52"
                                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 26;" />

                                        <Button text="⏭"
                                                onAction="#handleNext"
                                                prefWidth="62"
                                                prefHeight="42"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                        <Button fx:id="loopButton"
                                                text="↻"
                                                onAction="#handleLoop"
                                                prefWidth="70"
                                                prefHeight="42"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 21;" />

                                        <Region prefWidth="10" />

                                        <Button fx:id="likeButton"
                                                text="♡"
                                                onAction="#handleLike"
                                                prefWidth="70"
                                                prefHeight="44"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #ff0000; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 22;" />

                                        <Button fx:id="addToPlaylistButton"
                                                text="+"
                                                onAction="#handleAddToPlaylist"
                                                prefWidth="70"
                                                prefHeight="44"
                                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-size: 22px; -fx-font-weight: bold; -fx-background-radius: 22;" />
                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</StackPane>