<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.musicplayer.controller.ExpandedPlayerController"
           fx:id="overlayRoot"
           id="expandedPlayerOverlay"
           visible="false"
           managed="false"
           pickOnBounds="true">

    <!-- Backdrop -->
    <StackPane fx:id="backdropPane"
               styleClass="overlay-backdrop"
               onMouseClicked="#handleBackdropClick" />

    <!-- Player Card -->
    <VBox fx:id="playerCard"
          styleClass="overlay-card"
          alignment="CENTER"
          maxWidth="1060"
          prefWidth="1060"
          spacing="0"
          onMouseClicked="#handleConsumeClick">
        <children>

            <!-- Header row -->
            <HBox alignment="CENTER_LEFT"
                  styleClass="page-header">
                <children>
                    <VBox spacing="2">
                        <Label text="NOW PLAYING"
                               styleClass="overline, text-accent" />
                        <Label text="Expanded Player"
                               styleClass="heading-md" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✕"
                            onAction="#handleClose"
                            styleClass="btn-icon"
                            prefWidth="40" prefHeight="40" />
                </children>
            </HBox>

            <!-- Main content: art + info -->
            <HBox alignment="CENTER" spacing="44"
                  style="-fx-padding: 36 40 40 40;">
                <children>

                    <!-- Album Art -->
                    <VBox alignment="CENTER" spacing="14" prefWidth="320">
                        <StackPane prefWidth="300" prefHeight="300"
                                   styleClass="album-art-large">
                            <Label text="♫"
                                   style="-fx-font-size: 96px;
                                          -fx-text-fill: rgba(167,139,250,0.2);
                                          -fx-font-weight: bold;" />
                        </StackPane>
                        <Label text="TuneVault Player"
                               styleClass="body-sm" />
                    </VBox>

                    <!-- Song Info + Controls -->
                    <VBox spacing="24" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="580">
                        <children>

                            <!-- Track info -->
                            <VBox spacing="8">
                                <Label text="CURRENT TRACK"
                                       styleClass="overline" />

                                <Label fx:id="titleLabel"
                                       text="No song playing"
                                       wrapText="true"
                                       maxWidth="560"
                                       styleClass="heading-2xl"
                                       style="-fx-font-size: 40px; -fx-line-spacing: -2;" />

                                <Hyperlink fx:id="artistLink"
                                           text=""
                                           styleClass="heading-md"
                                           onAction="#handleOpenArtistProfile"
                                           style="-fx-text-fill: #9d9db8;" />

                                <Label fx:id="albumLabel"
                                       text="Album: -"
                                       styleClass="body-sm" />
                            </VBox>

                            <!-- Progress section -->
                            <VBox spacing="8"
                                  styleClass="progress-card">
                                <Slider fx:id="progressSlider"
                                        prefWidth="510"
                                        maxWidth="510" />
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Progress"
                                           styleClass="caption, text-muted" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="timeLabel"
                                           text="0:00 / 0:00"
                                           styleClass="body"
                                           style="-fx-font-weight: bold; -fx-text-fill: #9d9db8;" />
                                </HBox>
                            </VBox>

                            <!-- Playback Controls -->
                            <HBox alignment="CENTER_LEFT" spacing="10">

                                <Button fx:id="shuffleButton"
                                        text="⇄"
                                        onAction="#handleShuffle"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button text="⏮"
                                        onAction="#handlePrevious"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button fx:id="playPauseButton"
                                        text="▶"
                                        onAction="#handlePlayPause"
                                        styleClass="player-btn-main"
                                        prefWidth="64" prefHeight="56"
                                        style="-fx-font-size: 22px;" />

                                <Button text="⏭"
                                        onAction="#handleNext"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 20px;" />

                                <Button fx:id="loopButton"
                                        text="↻"
                                        onAction="#handleLoop"
                                        styleClass="player-btn"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 22px;" />

                                <Region prefWidth="16" />

                                <Button fx:id="likeButton"
                                        text="♡"
                                        onAction="#handleLike"
                                        styleClass="player-btn-like"
                                        prefWidth="52" prefHeight="44" />

                                <Button fx:id="addToPlaylistButton"
                                        text="+"
                                        onAction="#handleAddToPlaylist"
                                        styleClass="btn-accent-soft"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-font-size: 22px;" />

                            </HBox>

                        </children>
                    </VBox>

                </children>
            </HBox>

        </children>
    </VBox>

</StackPane>
