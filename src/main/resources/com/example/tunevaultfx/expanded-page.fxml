<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.musicplayer.controller.ExpandedPlayerController"
           fx:id="overlayRoot"
           id="expandedPlayerOverlay"
           visible="false"
           managed="false"
           pickOnBounds="true">

    <!-- ── Backdrop ───────────────────────────────── -->
    <StackPane fx:id="backdropPane"
               onMouseClicked="#handleBackdropClick"
               style="-fx-background-color: rgba(3, 2, 14, 0.75);" />

    <!-- ── Player Card ────────────────────────────── -->
    <VBox fx:id="playerCard"
          alignment="CENTER"
          maxWidth="1060"
          prefWidth="1060"
          spacing="0"
          onMouseClicked="#handleConsumeClick"
          style="-fx-background-color: #0e0e1a;
                 -fx-background-radius: 28;
                 -fx-border-color: rgba(255,255,255,0.08);
                 -fx-border-radius: 28;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 48, 0, 0, 16);">
        <children>

            <!-- ── Header row ──────────────────────── -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 22 28 18 28;
                         -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                         -fx-border-width: 0 0 1 0;">
                <children>
                    <VBox spacing="2">
                        <Label text="NOW PLAYING"
                               style="-fx-text-fill: #52525b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                        <Label text="Expanded Player"
                               style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✕"
                            onAction="#handleClose"
                            prefWidth="40" prefHeight="40"
                            style="-fx-background-color: rgba(255,255,255,0.07);
                                   -fx-text-fill: #6b6b8e;
                                   -fx-font-size: 16px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 20;
                                   -fx-border-color: rgba(255,255,255,0.1);
                                   -fx-border-radius: 20;
                                   -fx-border-width: 1;" />
                </children>
            </HBox>

            <!-- ── Main content: art + info ──────────── -->
            <HBox alignment="CENTER" spacing="44"
                  style="-fx-padding: 36 40 40 40;">
                <children>

                    <!-- Album Art -->
                    <VBox alignment="CENTER" spacing="14" prefWidth="320">
                        <StackPane prefWidth="300" prefHeight="300"
                                   style="-fx-background-color: linear-gradient(to bottom right, #1a0b3c, #2d1060);
                                          -fx-background-radius: 24;
                                          -fx-border-color: rgba(139,92,246,0.2);
                                          -fx-border-radius: 24;
                                          -fx-border-width: 1;
                                          -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.25), 32, 0, 0, 8);">
                            <Label text="♫"
                                   style="-fx-font-size: 96px;
                                          -fx-text-fill: rgba(167,139,250,0.2);
                                          -fx-font-weight: bold;" />
                        </StackPane>
                        <Label text="TuneVault Player"
                               style="-fx-text-fill: #3f3f5a; -fx-font-size: 13px;" />
                    </VBox>

                    <!-- Song Info + Controls -->
                    <VBox spacing="24" alignment="TOP_LEFT" HBox.hgrow="ALWAYS" maxWidth="580">
                        <children>

                            <!-- Track info -->
                            <VBox spacing="8">
                                <Label text="CURRENT TRACK"
                                       style="-fx-text-fill: #3f3f5a; -fx-font-size: 11px; -fx-font-weight: bold;" />

                                <Label fx:id="titleLabel"
                                       text="No song playing"
                                       wrapText="true"
                                       maxWidth="560"
                                       style="-fx-font-size: 40px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #ffffff;
                                              -fx-line-spacing: -2;" />

                                <Hyperlink fx:id="artistLink"
                                           text=""
                                           onAction="#handleOpenArtistProfile"
                                           style="-fx-font-size: 18px;
                                                  -fx-text-fill: #6b6b8e;
                                                  -fx-border-color: transparent;
                                                  -fx-padding: 0;" />

                                <Label fx:id="albumLabel"
                                       text="Album: -"
                                       style="-fx-font-size: 14px; -fx-text-fill: #3f3f5a;" />
                            </VBox>

                            <!-- Progress section -->
                            <VBox spacing="8"
                                  style="-fx-background-color: rgba(255,255,255,0.03);
                                         -fx-background-radius: 18;
                                         -fx-border-color: rgba(255,255,255,0.06);
                                         -fx-border-radius: 18;
                                         -fx-border-width: 1;
                                         -fx-padding: 16 20 14 20;">
                                <Slider fx:id="progressSlider"
                                        prefWidth="510"
                                        maxWidth="510" />
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Progress"
                                           style="-fx-text-fill: #3f3f5a; -fx-font-size: 12px;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="timeLabel"
                                           text="0:00 / 0:00"
                                           style="-fx-font-size: 14px;
                                                  -fx-font-weight: bold;
                                                  -fx-text-fill: #6b6b8e;" />
                                </HBox>
                            </VBox>

                            <!-- Playback Controls -->
                            <HBox alignment="CENTER_LEFT" spacing="10">

                                <Button fx:id="shuffleButton"
                                        text="⇄"
                                        onAction="#handleShuffle"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: #4a4a70;
                                               -fx-font-size: 20px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;" />

                                <Button text="⏮"
                                        onAction="#handlePrevious"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: #a1a1aa;
                                               -fx-font-size: 20px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;" />

                                <Button fx:id="playPauseButton"
                                        text="▶"
                                        onAction="#handlePlayPause"
                                        prefWidth="64" prefHeight="56"
                                        style="-fx-background-color: #ffffff;
                                               -fx-text-fill: #090912;
                                               -fx-font-size: 22px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 28;
                                               -fx-effect: dropshadow(gaussian,rgba(255,255,255,0.2),12,0,0,2);" />

                                <Button text="⏭"
                                        onAction="#handleNext"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: #a1a1aa;
                                               -fx-font-size: 20px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;" />

                                <Button fx:id="loopButton"
                                        text="↻"
                                        onAction="#handleLoop"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: #4a4a70;
                                               -fx-font-size: 22px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;" />

                                <Region prefWidth="16" />

                                <Button fx:id="likeButton"
                                        text="♡"
                                        onAction="#handleLike"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(244,63,94,0.1);
                                               -fx-text-fill: #6b6b8e;
                                               -fx-font-size: 20px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;
                                               -fx-border-color: rgba(244,63,94,0.15);
                                               -fx-border-radius: 22;
                                               -fx-border-width: 1;" />

                                <Button fx:id="addToPlaylistButton"
                                        text="+"
                                        onAction="#handleAddToPlaylist"
                                        prefWidth="52" prefHeight="44"
                                        style="-fx-background-color: rgba(139,92,246,0.1);
                                               -fx-text-fill: #6b6b8e;
                                               -fx-font-size: 22px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 22;
                                               -fx-border-color: rgba(139,92,246,0.15);
                                               -fx-border-radius: 22;
                                               -fx-border-width: 1;" />

                            </HBox>

                        </children>
                    </VBox>

                </children>
            </HBox>

        </children>
    </VBox>

</StackPane>
