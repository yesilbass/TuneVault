<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.auth.LoginPageController"
           styleClass="auth-bg"
           prefWidth="960.0" prefHeight="600.0">

    <VBox alignment="CENTER" styleClass="auth-card" spacing="28"
          style="-fx-max-width: 420;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="14">
            <StackPane styleClass="logo-icon-lg"
                       prefWidth="72" prefHeight="72" maxWidth="72" maxHeight="72">
                <Label text="♫" style="-fx-font-size: 34px; -fx-text-fill: white;" />
            </StackPane>
            <Label text="TuneVault" styleClass="auth-brand" />
            <Label text="Sign in to continue" styleClass="auth-subtitle" />
        </VBox>

        <!-- Form fields -->
        <VBox spacing="18">
            <VBox spacing="8">
                <Label text="USERNAME OR EMAIL" styleClass="field-label" />
                <TextField fx:id="usernameField"
                           promptText="Enter username or email"
                           prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label text="PASSWORD" styleClass="field-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink text="Forgot password?"
                               onAction="#openForgotPasswordPage" />
                </HBox>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               prefHeight="46" />
            </VBox>
        </VBox>

        <!-- Actions -->
        <VBox spacing="12">
            <Button fx:id="loginButton" text="Sign In"
                    onAction="#handleLogin"
                    defaultButton="true"
                    styleClass="btn-primary"
                    maxWidth="Infinity" prefHeight="46" />

            <Label fx:id="statusLabel" text="" wrapText="true"
                   style="-fx-max-width: 380;" />
        </VBox>

        <Separator />

        <!-- Footer link -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="New to TuneVault?" styleClass="body-sm" />
            <Hyperlink text="Create an account"
                       onAction="#handleCreateAccountPage" />
        </HBox>

    </VBox>

</StackPane>
