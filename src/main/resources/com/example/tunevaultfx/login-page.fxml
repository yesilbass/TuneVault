<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.auth.LoginPageController"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <children>
        <VBox alignment="CENTER" spacing="20.0"
              AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

            <children>
                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <Label text="TuneVault" style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;" />
                        <Label text="Music Analytics &amp; Personal Listening Experience"
                               style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;" />
                    </children>
                </VBox>

                <VBox prefWidth="360.0" maxWidth="360.0" alignment="CENTER_LEFT" spacing="16.0"
                      style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 30;">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Login" style="-fx-text-fill: #0f172a; -fx-font-size: 24px; -fx-font-weight: bold;" />
                                <Label text="Sign in to continue to TuneVault" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                            </children>
                        </VBox>

                        <Separator />

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Username or Email" style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                                <TextField fx:id="usernameField" promptText="Enter username or email" prefHeight="40.0"
                                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1; -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Password" style="-fx-text-fill: #334155; -fx-font-size: 13px; -fx-font-weight: bold;" />
                                <PasswordField fx:id="passwordField" promptText="Enter password" prefHeight="40.0"
                                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1; -fx-padding: 0 10 0 10;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Hyperlink text="Forgot Password?" onAction="#openForgotPasswordPage"
                                           style="-fx-text-fill: #2563eb; -fx-font-size: 12px;" />
                            </children>
                        </HBox>

                        <Button fx:id="loginButton" text="Login" prefWidth="300.0" prefHeight="42.0"
                                onAction="#handleLogin"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10;" />

                        <Label fx:id="statusLabel" text="" wrapText="true" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;" />

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="New to TuneVault?" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
                                <Hyperlink text="Create Account" onAction="#handleCreateAccountPage"
                                           style="-fx-text-fill: #2563eb; -fx-font-size: 12px;" />
                            </children>
                        </HBox>
                    </children>

                    <padding>
                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>