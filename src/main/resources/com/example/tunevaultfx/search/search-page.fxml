<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.search.SearchPageController"
            prefWidth="1280.0" prefHeight="820.0"
            styleClass="page-bg">

    <top>
        <fx:include source="../chrome/app-top-bar.fxml"/>
    </top>

    <left>
        <fx:include source="../chrome/app-sidebar.fxml"/>
    </left>
    <!-- ── CENTER ────────────────────────────────── -->
    <center>
        <VBox spacing="0" style="-fx-padding: 16 32 0 32;" maxWidth="Infinity" maxHeight="Infinity">

            <VBox fx:id="searchSummaryCard" spacing="8" styleClass="card" VBox.vgrow="NEVER">
                <Label text="Search" styleClass="heading-lg"/>
                <Label text="Use the bar at the top of the window. Results appear below."
                       styleClass="body-sm"
                       wrapText="true"
                       maxWidth="720"/>
                <Label fx:id="resultsSummaryLabel"
                       text=""
                       styleClass="caption"/>
            </VBox>

            <Region prefHeight="16" VBox.vgrow="NEVER"/>

            <!-- IDLE: Recent searches (visible when search is empty) -->
            <VBox fx:id="recentSection" spacing="0" styleClass="card" VBox.vgrow="ALWAYS" maxHeight="Infinity">

                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                    <Label text="Recent Searches" styleClass="heading-md"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Clear All"
                            onAction="#handleClearRecentSearches"
                            styleClass="btn-ghost"/>
                </HBox>

                <ListView fx:id="recentSearchesListView" minHeight="200" VBox.vgrow="ALWAYS" maxHeight="Infinity"/>
            </VBox>

            <!-- RESULTS: Shown while typing (scrollable) -->
            <ScrollPane fx:id="resultsScrollPane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        visible="false"
                        managed="false"
                        minHeight="240"
                        maxWidth="Infinity"
                        maxHeight="Infinity"
                        VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="16" style="-fx-padding: 0 0 28 0;">

                        <!-- People -->
                        <VBox fx:id="userResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane styleClass="icon-box-sm, icon-box-teal">
                                    <Label text="\u263A" style="-fx-font-size: 14px;"/>
                                </StackPane>
                                <Label text="People" styleClass="heading-md"/>
                            </HBox>

                            <ListView fx:id="userResultsListView" prefHeight="160"/>
                        </VBox>

                        <!-- Public playlists -->
                        <VBox fx:id="publicPlaylistResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane styleClass="icon-box-sm, icon-box-violet">
                                    <Label text="\u266A" styleClass="text-accent"/>
                                </StackPane>
                                <Label text="Public playlists" styleClass="heading-md"/>
                            </HBox>

                            <ListView fx:id="publicPlaylistResultsListView" prefHeight="200"/>
                        </VBox>

                        <!-- Songs & artists (single feed, ranked for this user) -->
                        <VBox fx:id="musicResultsSection"
                              spacing="0"
                              visible="false"
                              managed="false"
                              styleClass="card">

                            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 14 0;">
                                <StackPane styleClass="icon-box-sm, icon-box-violet">
                                    <Label text="♫" styleClass="text-accent"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label text="Music" styleClass="heading-md"/>
                                    <Label text="Songs and artists mixed by match and your listening"
                                           styleClass="caption"
                                           wrapText="true"
                                           maxWidth="520"/>
                                </VBox>
                            </HBox>

                            <ListView fx:id="musicResultsListView" prefHeight="420"/>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="../musicplayer/controller/mini-player.fxml"/>
    </bottom>

</BorderPane>
