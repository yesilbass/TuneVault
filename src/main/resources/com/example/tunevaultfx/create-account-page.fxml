<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.tunevaultfx.auth.CreateAccountPageController"
           styleClass="auth-bg"
           prefWidth="960.0" prefHeight="660.0">

    <VBox alignment="CENTER" styleClass="auth-card" spacing="24"
          style="-fx-max-width: 420;">

        <!-- Brand -->
        <VBox alignment="CENTER" spacing="14">
            <StackPane styleClass="logo-icon-lg"
                       prefWidth="72" prefHeight="72" maxWidth="72" maxHeight="72">
                <Label text="♫" style="-fx-font-size: 34px; -fx-text-fill: white;" />
            </StackPane>
            <Label text="Create your account" styleClass="auth-brand" />
            <Label text="It's free and takes under a minute" styleClass="auth-subtitle" />
        </VBox>

        <!-- Form fields -->
        <VBox spacing="14">
            <VBox spacing="8">
                <Label text="USERNAME" styleClass="field-label" />
                <TextField fx:id="usernameField"
                           promptText="3–30 characters, letters &amp; numbers"
                           prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <Label text="EMAIL" styleClass="field-label" />
                <TextField fx:id="emailField"
                           promptText="you@example.com"
                           prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <Label text="PASSWORD" styleClass="field-label" />
                <PasswordField fx:id="passwordField"
                               promptText="Create a strong password"
                               prefHeight="46" />
            </VBox>

            <VBox spacing="8">
                <Label text="CONFIRM PASSWORD" styleClass="field-label" />
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Repeat your password"
                               prefHeight="46" />
            </VBox>
        </VBox>

        <!-- Password requirements -->
        <VBox styleClass="info-box" spacing="8">
            <Label text="Password requirements" styleClass="caption" />
            <HBox spacing="8" alignment="CENTER_LEFT">
                <StackPane styleClass="bullet-dot,bullet-violet" />
                <Label text="At least 8 characters" styleClass="body-sm" />
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <StackPane styleClass="bullet-dot,bullet-violet" />
                <Label text="One uppercase &amp; one lowercase letter" styleClass="body-sm" />
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <StackPane styleClass="bullet-dot,bullet-violet" />
                <Label text="One number" styleClass="body-sm" />
            </HBox>
        </VBox>

        <!-- Actions -->
        <VBox spacing="10">
            <Button text="Create Account"
                    onAction="#handleCreateAccount"
                    defaultButton="true"
                    styleClass="btn-primary"
                    maxWidth="Infinity" prefHeight="46" />

            <Button text="← Back to Login"
                    onAction="#handleBackToLogin"
                    cancelButton="true"
                    styleClass="btn-secondary"
                    maxWidth="Infinity" prefHeight="46" />
        </VBox>

        <Label fx:id="statusLabel" text="" wrapText="true"
               style="-fx-max-width: 380;" />

    </VBox>

</StackPane>
