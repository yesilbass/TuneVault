<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.wrapped.WrappedPageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            style="-fx-background-color: #09090f;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 32 18 32;
                     -fx-border-color: transparent transparent rgba(255,255,255,0.07) transparent;
                     -fx-border-width: 0 0 1 0;">
            <Button text="← Menu" onAction="#handleBackToMenu"
                    prefWidth="110" prefHeight="38"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-text-fill: #a0a0c0; -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 19;
                           -fx-border-color: rgba(255,255,255,0.1);
                           -fx-border-radius: 19; -fx-border-width: 1;" />
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="📊" style="-fx-font-size: 22px;" />
                    <Label text="Wrapped"
                           style="-fx-text-fill: #f2f2fa; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </HBox>
            </StackPane>
            <Region prefWidth="110" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="18" style="-fx-padding: 22 32 28 32;">

                    <!-- Header: title + range toggle -->
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Your Listening Summary"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f2f2fa;" />
                            <Label fx:id="rangeTitleLabel" text="Today"
                                   style="-fx-font-size: 14px; -fx-text-fill: #a0a0c0;" />
                        </VBox>
                        <HBox spacing="8" alignment="CENTER">
                            <Button fx:id="todayButton" text="Today" onAction="#handleShowToday"
                                    prefWidth="96" prefHeight="36"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-background-radius: 18;" />
                            <Button fx:id="overallButton" text="Overall" onAction="#handleShowOverall"
                                    prefWidth="96" prefHeight="36"
                                    style="-fx-background-color: rgba(255,255,255,0.07);
                                           -fx-text-fill: #a0a0c0;
                                           -fx-font-size: 13px; -fx-font-weight: bold;
                                           -fx-background-radius: 18;
                                           -fx-border-color: rgba(255,255,255,0.1);
                                           -fx-border-radius: 18; -fx-border-width: 1;" />
                        </HBox>
                    </HBox>

                    <!-- 2×2 stats grid -->
                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>
                        <children>

                            <!-- Top Song -->
                            <VBox spacing="12"
                                  style="-fx-background-color: #0f0f1e;
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(139,92,246,0.18);
                                         -fx-border-radius: 22; -fx-border-width: 1;
                                         -fx-padding: 24;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.45),16,0,0,4);"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane prefWidth="36" prefHeight="36"
                                               style="-fx-background-color: rgba(139,92,246,0.18);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(139,92,246,0.28);
                                                      -fx-border-radius: 12; -fx-border-width: 1;">
                                        <Label text="♫" style="-fx-font-size: 15px; -fx-text-fill: #c4b5fd;" />
                                    </StackPane>
                                    <Label text="Top Song"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0a0c0;" />
                                </HBox>
                                <Label fx:id="topSongLabel" text="-" wrapText="true" maxWidth="460"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f2f2fa;" />
                                <Label fx:id="topSongArtistLabel" text="" wrapText="true" maxWidth="460"
                                       managed="false" visible="false"
                                       style="-fx-font-size: 14px; -fx-text-fill: #a0a0c0;" />
                                <ProgressBar fx:id="songBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Top Artist -->
                            <VBox spacing="12"
                                  style="-fx-background-color: #0f0f1e;
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(244,63,94,0.18);
                                         -fx-border-radius: 22; -fx-border-width: 1;
                                         -fx-padding: 24;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.45),16,0,0,4);"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane prefWidth="36" prefHeight="36"
                                               style="-fx-background-color: rgba(244,63,94,0.15);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(244,63,94,0.25);
                                                      -fx-border-radius: 12; -fx-border-width: 1;">
                                        <Label text="◎" style="-fx-font-size: 15px; -fx-text-fill: #fda4af;" />
                                    </StackPane>
                                    <Label text="Top Artist"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0a0c0;" />
                                </HBox>
                                <Label fx:id="topArtistLabel" text="-" wrapText="true" maxWidth="460"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f2f2fa;" />
                                <Label fx:id="topArtistTopSongLabel" text="" wrapText="true" maxWidth="460"
                                       managed="false" visible="false"
                                       style="-fx-font-size: 14px; -fx-text-fill: #a0a0c0;" />
                                <ProgressBar fx:id="artistBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Favorite Genre -->
                            <VBox spacing="12"
                                  style="-fx-background-color: #0f0f1e;
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(20,184,166,0.18);
                                         -fx-border-radius: 22; -fx-border-width: 1;
                                         -fx-padding: 24;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.45),16,0,0,4);"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane prefWidth="36" prefHeight="36"
                                               style="-fx-background-color: rgba(20,184,166,0.15);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(20,184,166,0.25);
                                                      -fx-border-radius: 12; -fx-border-width: 1;">
                                        <Label text="🎵" style="-fx-font-size: 15px;" />
                                    </StackPane>
                                    <Label text="Favorite Genre"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0a0c0;" />
                                </HBox>
                                <Label fx:id="favoriteGenreLabel" text="-" wrapText="true" maxWidth="460"
                                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f2f2fa;" />
                                <ProgressBar fx:id="genreBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Total Listening Time — accent card -->
                            <VBox spacing="10" alignment="CENTER_LEFT"
                                  style="-fx-background-color: linear-gradient(to bottom right, #1a0b3c, #0f0f1e);
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(139,92,246,0.3);
                                         -fx-border-radius: 22; -fx-border-width: 1;
                                         -fx-padding: 24;
                                         -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.25),20,0,0,4);"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane prefWidth="36" prefHeight="36"
                                               style="-fx-background-color: rgba(249,115,22,0.15);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(249,115,22,0.25);
                                                      -fx-border-radius: 12; -fx-border-width: 1;">
                                        <Label text="⏱" style="-fx-font-size: 15px;" />
                                    </StackPane>
                                    <Label text="Total Listening Time"
                                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0a0c0;" />
                                </HBox>
                                <Label fx:id="totalMinutesLabel" text="-"
                                       style="-fx-font-size: 46px; -fx-font-weight: bold; -fx-text-fill: #c4b5fd;" />
                                <Label text="time listened"
                                       style="-fx-font-size: 14px; -fx-text-fill: #a0a0c0;" />
                            </VBox>

                        </children>
                    </GridPane>

                    <!-- Summary card -->
                    <VBox spacing="14"
                          style="-fx-background-color: #0f0f1e;
                                 -fx-background-radius: 22;
                                 -fx-border-color: rgba(255,255,255,0.08);
                                 -fx-border-radius: 22; -fx-border-width: 1;
                                 -fx-padding: 24;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <StackPane prefWidth="32" prefHeight="32"
                                       style="-fx-background-color: rgba(139,92,246,0.14);
                                              -fx-background-radius: 10;
                                              -fx-border-color: rgba(139,92,246,0.22);
                                              -fx-border-radius: 10; -fx-border-width: 1;">
                                <Label text="✦" style="-fx-font-size: 12px; -fx-text-fill: #c4b5fd;" />
                            </StackPane>
                            <Label text="Summary"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #a0a0c0;" />
                        </HBox>
                        <Label fx:id="summaryLabel" text="-" wrapText="true" maxWidth="1100"
                               style="-fx-font-size: 16px; -fx-text-fill: #c8c8e0; -fx-line-spacing: 3px;" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>
