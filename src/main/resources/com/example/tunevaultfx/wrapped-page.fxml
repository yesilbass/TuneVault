<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.wrapped.WrappedPageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            style="-fx-background-color: linear-gradient(to bottom right, #090912, #0f0f1e);">

    <!-- ── TOP ───────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding: 22 32 18 32;
                     -fx-border-color: transparent transparent rgba(255,255,255,0.06) transparent;
                     -fx-border-width: 0 0 1 0;">
            <Button text="← Menu"
                    onAction="#handleBackToMenu"
                    prefWidth="110" prefHeight="38"
                    style="-fx-background-color: rgba(255,255,255,0.07);
                           -fx-text-fill: #94a3b8;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 19;
                           -fx-border-color: rgba(255,255,255,0.1);
                           -fx-border-radius: 19;
                           -fx-border-width: 1;" />

            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="📊"
                           style="-fx-font-size: 22px;" />
                    <Label text="Wrapped"
                           style="-fx-text-fill: #ffffff; -fx-font-size: 26px; -fx-font-weight: bold;" />
                </HBox>
            </StackPane>

            <Region prefWidth="110" />
        </HBox>
    </top>

    <!-- ── CENTER ────────────────────────────────── -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox spacing="20" style="-fx-padding: 22 32 28 32;">
                    <children>

                        <!-- ── Title + Range picker ──────────── -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Your Listening Summary"
                                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                                <Label fx:id="rangeTitleLabel"
                                       text="Today"
                                       style="-fx-font-size: 14px; -fx-text-fill: #52525b;" />
                            </VBox>

                            <!-- Range toggle pills -->
                            <HBox spacing="8" alignment="CENTER">
                                <Button fx:id="todayButton"
                                        text="Today"
                                        onAction="#handleShowToday"
                                        prefWidth="96" prefHeight="36"
                                        style="-fx-background-color: #8b5cf6;
                                               -fx-text-fill: white;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;" />
                                <Button fx:id="overallButton"
                                        text="Overall"
                                        onAction="#handleShowOverall"
                                        prefWidth="96" prefHeight="36"
                                        style="-fx-background-color: rgba(255,255,255,0.07);
                                               -fx-text-fill: #6b6b8e;
                                               -fx-font-size: 13px;
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 18;
                                               -fx-border-color: rgba(255,255,255,0.1);
                                               -fx-border-radius: 18;
                                               -fx-border-width: 1;" />
                            </HBox>
                        </HBox>

                        <!-- ── Top stats: 2-column grid ─────── -->
                        <GridPane hgap="18" vgap="18">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                            <children>

                                <!-- Top Song -->
                                <VBox spacing="12"
                                      style="-fx-background-color: #14141e;
                                             -fx-background-radius: 22;
                                             -fx-border-color: rgba(255,255,255,0.07);
                                             -fx-border-radius: 22;
                                             -fx-border-width: 1;
                                             -fx-padding: 24;
                                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <StackPane prefWidth="36" prefHeight="36"
                                                       style="-fx-background-color: rgba(139,92,246,0.15);
                                                              -fx-background-radius: 12;
                                                              -fx-border-color: rgba(139,92,246,0.2);
                                                              -fx-border-radius: 12;
                                                              -fx-border-width: 1;">
                                                <Label text="♫"
                                                       style="-fx-font-size: 16px; -fx-text-fill: #a78bfa;" />
                                            </StackPane>
                                            <Label text="Top Song"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                                        </HBox>
                                        <Label fx:id="topSongLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="460"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                                        <Label fx:id="topSongArtistLabel"
                                               text=""
                                               wrapText="true"
                                               maxWidth="460"
                                               managed="false"
                                               visible="false"
                                               style="-fx-font-size: 14px; -fx-text-fill: #52525b;" />
                                        <ProgressBar fx:id="songBar"
                                                     maxWidth="Infinity"
                                                     prefHeight="6" />
                                    </children>
                                </VBox>

                                <!-- Top Artist -->
                                <VBox spacing="12"
                                      style="-fx-background-color: #14141e;
                                             -fx-background-radius: 22;
                                             -fx-border-color: rgba(255,255,255,0.07);
                                             -fx-border-radius: 22;
                                             -fx-border-width: 1;
                                             -fx-padding: 24;
                                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <StackPane prefWidth="36" prefHeight="36"
                                                       style="-fx-background-color: rgba(244,63,94,0.15);
                                                              -fx-background-radius: 12;
                                                              -fx-border-color: rgba(244,63,94,0.2);
                                                              -fx-border-radius: 12;
                                                              -fx-border-width: 1;">
                                                <Label text="◎"
                                                       style="-fx-font-size: 16px; -fx-text-fill: #fb7185;" />
                                            </StackPane>
                                            <Label text="Top Artist"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                                        </HBox>
                                        <Label fx:id="topArtistLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="460"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                                        <Label fx:id="topArtistTopSongLabel"
                                               text=""
                                               wrapText="true"
                                               maxWidth="460"
                                               managed="false"
                                               visible="false"
                                               style="-fx-font-size: 14px; -fx-text-fill: #52525b;" />
                                        <ProgressBar fx:id="artistBar"
                                                     maxWidth="Infinity"
                                                     prefHeight="6" />
                                    </children>
                                </VBox>

                                <!-- Favorite Genre -->
                                <VBox spacing="12"
                                      style="-fx-background-color: #14141e;
                                             -fx-background-radius: 22;
                                             -fx-border-color: rgba(255,255,255,0.07);
                                             -fx-border-radius: 22;
                                             -fx-border-width: 1;
                                             -fx-padding: 24;
                                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <StackPane prefWidth="36" prefHeight="36"
                                                       style="-fx-background-color: rgba(20,184,166,0.15);
                                                              -fx-background-radius: 12;
                                                              -fx-border-color: rgba(20,184,166,0.2);
                                                              -fx-border-radius: 12;
                                                              -fx-border-width: 1;">
                                                <Label text="🎵"
                                                       style="-fx-font-size: 15px;" />
                                            </StackPane>
                                            <Label text="Favorite Genre"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                                        </HBox>
                                        <Label fx:id="favoriteGenreLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="460"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                                        <ProgressBar fx:id="genreBar"
                                                     maxWidth="Infinity"
                                                     prefHeight="6" />
                                    </children>
                                </VBox>

                                <!-- Total Listening Time -->
                                <VBox spacing="10"
                                      alignment="CENTER_LEFT"
                                      style="-fx-background-color: linear-gradient(to bottom right, #1a0b3c, #0e0e1a);
                                             -fx-background-radius: 22;
                                             -fx-border-color: rgba(139,92,246,0.2);
                                             -fx-border-radius: 22;
                                             -fx-border-width: 1;
                                             -fx-padding: 24;
                                             -fx-effect: dropshadow(gaussian,rgba(139,92,246,0.2),16,0,0,4);"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <StackPane prefWidth="36" prefHeight="36"
                                                       style="-fx-background-color: rgba(249,115,22,0.15);
                                                              -fx-background-radius: 12;
                                                              -fx-border-color: rgba(249,115,22,0.2);
                                                              -fx-border-radius: 12;
                                                              -fx-border-width: 1;">
                                                <Label text="⏱"
                                                       style="-fx-font-size: 16px;" />
                                            </StackPane>
                                            <Label text="Total Listening Time"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #52525b;" />
                                        </HBox>
                                        <Label fx:id="totalMinutesLabel"
                                               text="-"
                                               style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;" />
                                        <Label text="time listened"
                                               style="-fx-font-size: 14px; -fx-text-fill: #3f3f5a;" />
                                    </children>
                                </VBox>

                            </children>
                        </GridPane>

                        <!-- ── Summary card ──────────────────── -->
                        <VBox spacing="14"
                              style="-fx-background-color: #14141e;
                                     -fx-background-radius: 22;
                                     -fx-border-color: rgba(255,255,255,0.07);
                                     -fx-border-radius: 22;
                                     -fx-border-width: 1;
                                     -fx-padding: 24;
                                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),16,0,0,4);">
                            <children>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane prefWidth="32" prefHeight="32"
                                               style="-fx-background-color: rgba(139,92,246,0.12);
                                                      -fx-background-radius: 10;
                                                      -fx-border-color: rgba(139,92,246,0.18);
                                                      -fx-border-radius: 10;
                                                      -fx-border-width: 1;">
                                        <Label text="✦"
                                               style="-fx-font-size: 13px; -fx-text-fill: #a78bfa;" />
                                    </StackPane>
                                    <Label text="Summary"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #6b6b8e;" />
                                </HBox>

                                <Label fx:id="summaryLabel"
                                       text="-"
                                       wrapText="true"
                                       maxWidth="1100"
                                       style="-fx-font-size: 16px;
                                              -fx-text-fill: #a1a1aa;
                                              -fx-line-spacing: 3px;" />
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ── BOTTOM ─────────────────────────────────── -->
    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>

</BorderPane>
