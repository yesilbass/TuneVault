<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.wrapped.WrappedPageController"
            prefWidth="1280.0" prefHeight="820.0"
            minWidth="1180.0" minHeight="780.0"
            styleClass="page-bg">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
            <Button text="← Back" onAction="#handleBackToMenu" styleClass="btn-nav" />
            <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                <HBox alignment="CENTER" spacing="10">
                    <Label text="📊" style="-fx-font-size: 22px;" />
                    <Label text="Wrapped" styleClass="heading-xl" />
                </HBox>
            </StackPane>
            <Region prefWidth="110" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox fx:id="wrappedContent" spacing="18" styleClass="page-content">

                    <!-- Header: title + range toggle -->
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Your Listening Summary" styleClass="heading-xl" />
                            <Label fx:id="rangeTitleLabel" text="Today" styleClass="body-sm" />
                        </VBox>
                        <HBox spacing="8" alignment="CENTER">
                            <Button fx:id="todayButton" text="Today" onAction="#handleShowToday"
                                    prefWidth="96" prefHeight="36"
                                    styleClass="btn-toggle-active" />
                            <Button fx:id="overallButton" text="Overall" onAction="#handleShowOverall"
                                    prefWidth="96" prefHeight="36"
                                    styleClass="btn-toggle-inactive" />
                        </HBox>
                    </HBox>

                    <!-- 2×2 stats grid -->
                    <GridPane fx:id="statsGrid" hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>
                        <children>

                            <!-- Top Song -->
                            <VBox fx:id="topSongCard" spacing="12"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="card-violet" />
                                </styleClass>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane>
                                        <styleClass>
                                            <String fx:value="icon-box-sm" />
                                            <String fx:value="icon-box-violet" />
                                        </styleClass>
                                        <Label text="♫" style="-fx-font-size: 15px; -fx-text-fill: #c4b5fd;" />
                                    </StackPane>
                                    <Label text="Top Song" styleClass="body-sm" />
                                </HBox>
                                <Label fx:id="topSongLabel" text="-" wrapText="true" maxWidth="460"
                                       styleClass="heading-lg" />
                                <Label fx:id="topSongArtistLabel" text="" wrapText="true" maxWidth="460"
                                       managed="false" visible="false"
                                       styleClass="body-sm" />
                                <ProgressBar fx:id="songBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Top Artist -->
                            <VBox fx:id="topArtistCard" spacing="12"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="card-rose" />
                                </styleClass>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane>
                                        <styleClass>
                                            <String fx:value="icon-box-sm" />
                                            <String fx:value="icon-box-rose" />
                                        </styleClass>
                                        <Label text="◎" style="-fx-font-size: 15px; -fx-text-fill: #fda4af;" />
                                    </StackPane>
                                    <Label text="Top Artist" styleClass="body-sm" />
                                </HBox>
                                <Label fx:id="topArtistLabel" text="-" wrapText="true" maxWidth="460"
                                       styleClass="heading-lg" />
                                <Label fx:id="topArtistTopSongLabel" text="" wrapText="true" maxWidth="460"
                                       managed="false" visible="false"
                                       styleClass="body-sm" />
                                <ProgressBar fx:id="artistBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Favorite Genre -->
                            <VBox fx:id="genreCard" spacing="12"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <styleClass>
                                    <String fx:value="card" />
                                    <String fx:value="card-teal" />
                                </styleClass>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane>
                                        <styleClass>
                                            <String fx:value="icon-box-sm" />
                                            <String fx:value="icon-box-teal" />
                                        </styleClass>
                                        <Label text="🎵" style="-fx-font-size: 15px;" />
                                    </StackPane>
                                    <Label text="Favorite Genre" styleClass="body-sm" />
                                </HBox>
                                <Label fx:id="favoriteGenreLabel" text="-" wrapText="true" maxWidth="460"
                                       styleClass="heading-lg" />
                                <ProgressBar fx:id="genreBar" maxWidth="Infinity" prefHeight="6" />
                            </VBox>

                            <!-- Total Listening Time — accent card -->
                            <VBox fx:id="timeCard" spacing="10" alignment="CENTER_LEFT"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1"
                                  styleClass="card-time-gradient">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <StackPane>
                                        <styleClass>
                                            <String fx:value="icon-box-sm" />
                                            <String fx:value="icon-box-orange" />
                                        </styleClass>
                                        <Label text="⏱" style="-fx-font-size: 15px;" />
                                    </StackPane>
                                    <Label text="Total Listening Time" styleClass="body-sm" />
                                </HBox>
                                <Label fx:id="totalMinutesLabel" text="-" styleClass="stat-number" />
                                <Label text="time listened" styleClass="body-sm" />
                            </VBox>

                        </children>
                    </GridPane>

                    <!-- Summary card -->
                    <VBox fx:id="summaryCard" spacing="14" styleClass="card">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <StackPane>
                                <styleClass>
                                    <String fx:value="icon-box-sm" />
                                    <String fx:value="icon-box-violet" />
                                </styleClass>
                                <Label text="✦" style="-fx-font-size: 12px; -fx-text-fill: #c4b5fd;" />
                            </StackPane>
                            <Label text="Summary" styleClass="heading-md" />
                        </HBox>
                        <Label fx:id="summaryLabel" text="-" wrapText="true" maxWidth="1100"
                               styleClass="body" />
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>
