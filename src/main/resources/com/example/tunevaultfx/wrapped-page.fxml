<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.tunevaultfx.wrapped.WrappedPageController"
            prefWidth="1280.0" prefHeight="920.0"
            minWidth="1180.0" minHeight="780.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 20 24 24 24;">
            <children>
                <Button text="Back to Menu"
                        onAction="#handleBackToMenu"
                        prefWidth="120" prefHeight="38"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 20;" />

                <StackPane HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label text="Wrapped"
                           style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                </StackPane>

                <Region prefWidth="120" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" pickOnBounds="false" style="-fx-padding: 30 24 36 24;">
            <children>
                <VBox spacing="18"
                      alignment="TOP_CENTER"
                      pickOnBounds="false"
                      maxHeight="560"
                      prefHeight="560"
                      style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 24;"
                      maxWidth="920"
                      prefWidth="920">
                    <children>

                        <VBox alignment="CENTER" spacing="8">
                            <children>
                                <Label text="Your Listening Summary"
                                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111827;" />

                                <Label fx:id="rangeTitleLabel"
                                       text="Today"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="12">
                            <children>
                                <Button fx:id="todayButton"
                                        text="Today"
                                        onAction="#handleShowToday"
                                        prefWidth="110"
                                        prefHeight="38"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 19;" />

                                <Button fx:id="overallButton"
                                        text="Overall"
                                        onAction="#handleShowOverall"
                                        prefWidth="110"
                                        prefHeight="38"
                                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 19;" />
                            </children>
                        </HBox>

                        <GridPane hgap="22" vgap="22">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>

                            <children>
                                <VBox spacing="10"
                                      style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 20;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="Top Song"
                                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                        <Label fx:id="topSongLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="360"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                                        <ProgressBar fx:id="songBar"
                                                     prefWidth="380"
                                                     prefHeight="10" />
                                    </children>
                                </VBox>

                                <VBox spacing="10"
                                      style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 20;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <children>
                                        <Label text="Top Artist"
                                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                        <Label fx:id="topArtistLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="360"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                                        <ProgressBar fx:id="artistBar"
                                                     prefWidth="380"
                                                     prefHeight="10" />
                                    </children>
                                </VBox>

                                <VBox spacing="10"
                                      style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 20;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Favorite Genre"
                                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                        <Label fx:id="favoriteGenreLabel"
                                               text="-"
                                               wrapText="true"
                                               maxWidth="360"
                                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                                        <ProgressBar fx:id="genreBar"
                                                     prefWidth="380"
                                                     prefHeight="10" />
                                    </children>
                                </VBox>

                                <VBox spacing="10"
                                      alignment="CENTER_LEFT"
                                      style="-fx-background-color: #eff6ff; -fx-background-radius: 20; -fx-padding: 20;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Total Listening Time"
                                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
                                        <Label fx:id="totalMinutesLabel"
                                               text="-"
                                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1d4ed8;" />
                                        <Label text="minutes listened"
                                               style="-fx-font-size: 15px; -fx-text-fill: #475569;" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <VBox spacing="12"
                              style="-fx-background-color: #f8fafc; -fx-background-radius: 20; -fx-padding: 22;"
                              prefHeight="170"
                              minHeight="170">
                            <children>
                                <Label text="Summary"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />

                                <Label fx:id="summaryLabel"
                                       text="-"
                                       wrapText="true"
                                       maxWidth="800"
                                       prefWidth="800"
                                       minHeight="90"
                                       style="-fx-font-size: 18px; -fx-text-fill: #334155; -fx-line-spacing: 4px;" />
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <fx:include source="mini-player.fxml" />
    </bottom>
</BorderPane>